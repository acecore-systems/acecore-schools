---
import SchoolsPage from "../../components/SchoolsPage.astro";
import { defaultLocale, locales, type Locale } from "../../data/schools";

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
---

<SchoolsPage locale={locale} />
