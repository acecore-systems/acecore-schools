---
import {
  acecoreOrigin,
  lineUrl,
  schoolsContent,
  schoolsOrigin,
} from "../data/schools";

const content = schoolsContent;
const canonicalPath = "/contact/";
const canonicalUrl = new URL(canonicalPath, schoolsOrigin).href;
const courses = [
  content.juku.title,
  content.robotProgramming.title,
  content.practicalProgramming.title,
  content.pcSmartphone.title,
  content.ged.title,
  "まだ決まっていない",
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>お問い合わせフォーム | Acecore Schools</title>
    <meta
      name="description"
      content="Acecore Schoolsの見学、体験授業、コース相談を受け付ける専用お問い合わせフォームです。"
    />
    <link rel="canonical" href={canonicalUrl} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Acecore Schools">
        <span class="brand-mark" aria-hidden="true"></span>
        <span class="brand-text">Acecore <small>Schools</small></span>
      </a>
      <nav aria-label="Primary navigation">
        <a href="/">Schools</a>
        <a href={acecoreOrigin}>Acecore.net</a>
      </nav>
    </header>

    <main>
      <section class="contact-hero">
        <p class="eyebrow">Contact</p>
        <h1>お問い合わせフォーム</h1>
        <p>
          見学・体験授業、コース選び、料金の確認などを受け付けています。
          内容を確認して、担当者より折り返しご連絡します。
        </p>
      </section>

      <section class="contact-layout" aria-label="問い合わせフォーム">
        <form class="contact-form" action="/api/contact" method="post">
          <input
            class="hp-field"
            type="text"
            name="company"
            tabindex="-1"
            autocomplete="off"
          />

          <label>
            <span>お名前 <strong>必須</strong></span>
            <input
              name="name"
              type="text"
              autocomplete="name"
              required
              maxlength="80"
            />
          </label>

          <label>
            <span>メールアドレス <strong>必須</strong></span>
            <input
              name="email"
              type="email"
              autocomplete="email"
              required
              maxlength="120"
            />
          </label>

          <label>
            <span>電話番号</span>
            <input name="phone" type="tel" autocomplete="tel" maxlength="40" />
          </label>

          <label>
            <span>相談したい内容</span>
            <select name="course">
              <option value="">選択してください</option>
              {courses.map((course) => <option value={course}>{course}</option>)}
            </select>
          </label>

          <label class="full">
            <span>お問い合わせ内容 <strong>必須</strong></span>
            <textarea name="message" required maxlength="2000" rows="7"></textarea>
          </label>

          <label class="consent full">
            <input name="consent" type="checkbox" value="yes" required />
            <span>送信内容を確認し、連絡に同意します。</span>
          </label>

          <div class="form-actions full">
            <button type="submit">送信する</button>
            <p class="form-status" role="status" aria-live="polite"></p>
          </div>
        </form>

        <aside class="contact-side">
          <h2>LINEでも相談できます</h2>
          <p>
            急ぎの確認や短い相談はLINEも利用できます。フォームでは詳しい内容を残せます。
          </p>
          <a href={lineUrl} target="_blank" rel="noopener noreferrer">
            LINEで問い合わせる
          </a>
        </aside>
      </section>
    </main>

    <script>
      const form = document.querySelector(".contact-form");
      const status = document.querySelector(".form-status");

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!(form instanceof HTMLFormElement)) return;
        if (!(status instanceof HTMLElement)) return;

        const button = form.querySelector("button");
        const formData = new FormData(form);
        const payload = Object.fromEntries(formData.entries());

        status.textContent = "送信しています。";
        button?.setAttribute("disabled", "true");

        try {
          const response = await fetch(form.action, {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify(payload),
          });
          const result = await response.json().catch(() => ({}));

          if (!response.ok) {
            throw new Error(result.message || "送信できませんでした。");
          }

          form.reset();
          status.textContent =
            "送信しました。内容を確認して担当者よりご連絡します。";
        } catch (error) {
          status.textContent =
            error instanceof Error
              ? error.message
              : "送信できませんでした。時間をおいて再度お試しください。";
        } finally {
          button?.removeAttribute("disabled");
        }
      });
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --page: #fbfcfc;
    --paper: #ffffff;
    --ink: #111717;
    --muted: #667574;
    --line: rgba(17, 23, 23, 0.14);
    --teal: #008f8a;
    --teal-deep: #006b69;
    --teal-soft: #e3f7f4;
    --coral: #ff624f;
    --lime: #16b83e;
    font-family:
      Inter,
      "Noto Sans JP",
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    background: var(--page);
    color: var(--ink);
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    min-width: 320px;
    margin: 0;
    overflow-x: hidden;
    background: var(--page);
  }

  a {
    color: inherit;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 18px max(22px, calc((100vw - 1120px) / 2));
    background: rgba(255, 255, 255, 0.94);
    border-bottom: 1px solid var(--line);
  }

  .brand,
  nav,
  .contact-side a,
  .form-actions {
    display: flex;
    align-items: center;
  }

  .brand {
    gap: 9px;
    color: var(--teal-deep);
    font-size: 1.28rem;
    font-weight: 900;
    line-height: 0.98;
    text-decoration: none;
  }

  .brand-text {
    display: grid;
  }

  .brand small {
    color: #657171;
    font-size: 0.82rem;
    font-weight: 760;
  }

  .brand-mark {
    position: relative;
    display: block;
    flex: 0 0 auto;
    width: 32px;
    height: 38px;
  }

  .brand-mark::before,
  .brand-mark::after {
    position: absolute;
    bottom: 0;
    width: 12px;
    border-radius: 2px 2px 0 0;
    content: "";
  }

  .brand-mark::before {
    left: 5px;
    height: 38px;
    background: var(--teal);
    transform: skew(-28deg);
  }

  .brand-mark::after {
    right: 5px;
    height: 26px;
    background: var(--coral);
    transform: skew(28deg);
  }

  nav {
    gap: 8px;
  }

  nav a {
    border-radius: 6px;
    padding: 9px 12px;
    color: var(--ink);
    font-size: 0.86rem;
    font-weight: 860;
    text-decoration: none;
  }

  nav a:hover {
    background: var(--teal-soft);
    color: var(--teal-deep);
  }

  main {
    width: 100%;
    max-width: 100vw;
    min-width: 0;
    padding: 56px max(22px, calc((100vw - 1120px) / 2)) 72px;
    overflow-x: hidden;
  }

  .contact-hero {
    min-width: 0;
    max-width: 760px;
  }

  .eyebrow {
    display: inline-flex;
    border-radius: 8px;
    padding: 8px 14px;
    background: var(--teal);
    color: white;
    font-size: 0.78rem;
    font-weight: 900;
  }

  h1,
  h2,
  p {
    margin: 0;
  }

  h1 {
    max-width: 100%;
    margin-top: 18px;
    font-size: clamp(2.7rem, 7vw, 4.6rem);
    line-height: 0.98;
    letter-spacing: 0;
    overflow-wrap: anywhere;
    word-break: normal;
  }

  .contact-hero p {
    max-width: 620px;
    min-width: 0;
    margin-top: 18px;
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.9;
    overflow-wrap: anywhere;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 28px;
    width: 100%;
    min-width: 0;
    margin-top: 34px;
  }

  .contact-form,
  .contact-side {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
    box-shadow: 0 18px 50px rgba(12, 46, 51, 0.1);
  }

  .contact-form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    padding: 28px;
  }

  label {
    display: grid;
    gap: 8px;
    min-width: 0;
    color: var(--ink);
    font-size: 0.88rem;
    font-weight: 840;
  }

  label strong {
    color: var(--coral);
    font-size: 0.72rem;
  }

  .full {
    grid-column: 1 / -1;
  }

  input,
  select,
  textarea {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    min-height: 46px;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 12px 13px;
    background: #fbfcfc;
    color: var(--ink);
    font: inherit;
    font-weight: 650;
  }

  textarea {
    resize: vertical;
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: 3px solid rgba(0, 143, 138, 0.16);
    border-color: var(--teal);
  }

  .consent {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    min-width: 0;
    color: var(--muted);
    font-size: 0.86rem;
    font-weight: 760;
    line-height: 1.7;
    overflow-wrap: anywhere;
  }

  .consent input {
    width: 18px;
    min-width: 18px;
    min-height: 18px;
    margin-top: 5px;
  }

  .consent span {
    min-width: 0;
  }

  .form-actions {
    gap: 16px;
    flex-wrap: wrap;
  }

  button,
  .contact-side a {
    min-height: 46px;
    border: 0;
    border-radius: 8px;
    padding: 13px 22px;
    color: white;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 920;
    text-decoration: none;
  }

  button {
    background: var(--coral);
    cursor: pointer;
    box-shadow: 0 16px 30px rgba(255, 98, 79, 0.24);
  }

  button:disabled {
    opacity: 0.62;
    cursor: wait;
  }

  .form-status {
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 760;
  }

  .contact-side {
    align-self: start;
    padding: 26px;
  }

  .contact-side h2 {
    font-size: 1.45rem;
    line-height: 1.25;
  }

  .contact-side p {
    margin-top: 12px;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.85;
  }

  .contact-side a {
    justify-content: center;
    margin-top: 20px;
    background: var(--lime);
  }

  .hp-field {
    position: absolute;
    left: -9999px;
  }

  @media (max-width: 820px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    main {
      padding-top: 42px;
    }

    .contact-layout,
    .contact-form {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .site-header {
      padding-inline: 16px;
    }

    .brand small {
      display: none;
    }

    nav {
      width: 100%;
    }

    nav a {
      flex: 1;
      text-align: center;
    }

    main {
      padding: 36px 16px 56px;
    }

    .contact-form {
      width: 100%;
      max-width: 100%;
      gap: 16px;
      overflow: hidden;
      padding: 16px;
    }

    .contact-hero,
    .contact-layout,
    .contact-side {
      width: min(100%, calc(100vw - 32px));
      max-width: calc(100vw - 32px);
    }

    .contact-hero p {
      font-size: 0.92rem;
      line-height: 1.82;
      word-break: break-all;
    }

    h1 {
      max-width: 8em;
      font-size: 2rem;
      line-height: 1.08;
      word-break: break-all;
    }

    .consent span,
    .form-status {
      word-break: break-all;
    }

    .contact-form > * {
      max-width: 100%;
      min-width: 0;
    }

    .consent {
      display: grid;
      grid-template-columns: 18px minmax(0, 1fr);
    }

    .form-actions,
    button {
      width: 100%;
    }
  }
</style>
