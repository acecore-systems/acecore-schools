---
import {
  acecoreOrigin,
  defaultLocale,
  getLocalePath,
  getLocalizedAcecoreUrl,
  htmlLangMap,
  lineUrl,
  localeLabels,
  locales,
  schoolsContent,
  schoolsOrigin,
  type Locale,
} from "../data/schools";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = schoolsContent[locale] ?? schoolsContent[defaultLocale];
const canonicalPath = getLocalePath(locale);
const canonicalUrl = new URL(canonicalPath, schoolsOrigin).href;
const pricingUrl = getLocalizedAcecoreUrl(locale, "/pricing/");
const contactUrl = getLocalizedAcecoreUrl(locale, "/contact/");

const heroImage =
  "https://images.unsplash.com/photo-1509062522246-3755977927d7?w=1800&h=1100&fit=crop&q=86&fm=webp";
const jukuImage =
  "https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=1000&h=700&fit=crop&q=84&fm=webp";
const programmingImage =
  "https://images.unsplash.com/photo-1488590528505-98d2b5aba04b?w=1000&h=700&fit=crop&q=84&fm=webp";
const practicalImage =
  "https://images.unsplash.com/photo-1515879218367-8466d910aaa4?w=1000&h=700&fit=crop&q=84&fm=webp";
const pcImage =
  "https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=1000&h=700&fit=crop&q=84&fm=webp";
const gedImage =
  "https://images.unsplash.com/photo-1456513080510-7bf3a84b82f8?w=1000&h=700&fit=crop&q=84&fm=webp";

const iconMap = {
  mail: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4.5 6.5h15v11h-15z"/><path d="m5 7 7 6 7-6"/></svg>`,
  chat: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 6.75c0-1.24 1.01-2.25 2.25-2.25h9.5c1.24 0 2.25 1.01 2.25 2.25v6.5c0 1.24-1.01 2.25-2.25 2.25h-4.5L8 19.5v-4H7.25C6.01 15.5 5 14.49 5 13.25z"/><path d="M8.5 9.5h7M8.5 12.25h4.75"/></svg>`,
  sparkles: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 3 1.7 5.2L19 10l-5.3 1.8L12 17l-1.7-5.2L5 10l5.3-1.8z"/><path d="m18.5 15 .8 2.2 2.2.8-2.2.8-.8 2.2-.8-2.2-2.2-.8 2.2-.8z"/></svg>`,
  bot: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 8.5h8a3 3 0 0 1 3 3v5a3 3 0 0 1-3 3H8a3 3 0 0 1-3-3v-5a3 3 0 0 1 3-3Z"/><path d="M12 8.5V5M9 5h6M9.25 13h.01M14.75 13h.01M9 16h6"/></svg>`,
  code: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 8-4 4 4 4M15 8l4 4-4 4"/><path d="m13 6-2 12"/></svg>`,
  flag: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 21V4.5"/><path d="M6 5h10.5l-1.8 4 1.8 4H6"/></svg>`,
  login: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 5h4a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-4"/><path d="m10 8 4 4-4 4M14 12H4"/></svg>`,
  calendar: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 5.5h14v14H5z"/><path d="M8 3.5v4M16 3.5v4M5 9h14"/></svg>`,
  book: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4.5 5.5A3.5 3.5 0 0 1 8 2h11v17H8a3.5 3.5 0 0 0-3.5 3.5z"/><path d="M8 2v17"/></svg>`,
} as const;

const getStepIcon = (icon: string) => {
  if (icon === "bot") return iconMap.bot;
  if (icon === "code-xml") return iconMap.code;
  if (icon === "flag") return iconMap.flag;
  return iconMap.sparkles;
};

const getPricingIcon = (icon: string) => {
  if (icon === "calendar-days") return iconMap.calendar;
  if (icon === "book-open") return iconMap.book;
  return iconMap.login;
};

const courseSections = [
  {
    id: "juku",
    kicker: "01",
    title: content.juku.title,
    body: content.juku.desc,
    image: jukuImage,
    imageAlt: content.juku.imgAlt,
    listTitle: content.juku.featuresLabel,
    items: content.juku.features,
  },
  {
    id: "robot-programming",
    kicker: "02",
    title: content.robotProgramming.title,
    body: content.robotProgramming.desc,
    image: programmingImage,
    imageAlt: content.robotProgramming.progImgAlt,
    courses: content.robotProgramming.courses,
  },
  {
    id: "practical-programming",
    kicker: "03",
    title: content.practicalProgramming.title,
    body: content.practicalProgramming.desc,
    image: practicalImage,
    imageAlt: content.robotProgramming.progImgAlt,
    listTitle: content.practicalProgramming.contentsLabel,
    items: content.practicalProgramming.contents,
  },
  {
    id: "pc-smartphone",
    kicker: "04",
    title: content.pcSmartphone.title,
    body: content.pcSmartphone.desc,
    image: pcImage,
    imageAlt: content.pcSmartphone.imgAlt,
    listTitle: content.pcSmartphone.levelsLabel,
    items: content.pcSmartphone.levels,
  },
  {
    id: "ged",
    kicker: "05",
    title: content.ged.title,
    body: content.ged.desc,
    image: gedImage,
    imageAlt: content.ged.title,
    listTitle: content.ged.supportLabel,
    items: content.ged.supports,
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "EducationalOrganization",
      name: "Acecore Schools",
      description: content.description,
      url: canonicalUrl,
      parentOrganization: {
        "@type": "Organization",
        name: "Acecore",
        url: acecoreOrigin,
      },
    },
    ...courseSections.map((section) => ({
      "@type": "Course",
      name: section.title,
      description: section.body,
      provider: { "@type": "EducationalOrganization", name: "Acecore Schools" },
      url: `${canonicalUrl}#${section.id}`,
    })),
  ],
};
---

<!doctype html>
<html lang={htmlLangMap[locale]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{content.title} | Acecore</title>
    <meta name="description" content={content.description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={`${content.title} | Acecore`} />
    <meta property="og:description" content={content.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={heroImage} />
    <meta name="twitter:card" content="summary_large_image" />
    {
      locales.map((alternateLocale) => (
        <link
          rel="alternate"
          hreflang={htmlLangMap[alternateLocale]}
          href={new URL(getLocalePath(alternateLocale), schoolsOrigin).href}
        />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={`${schoolsOrigin}/`} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={canonicalPath} aria-label="Acecore Schools">
        <span class="brand-mark" aria-hidden="true">A</span>
        <span>Acecore Schools</span>
      </a>
      <nav class="primary-nav" aria-label="School sections">
        <a href="#juku">{content.juku.title}</a>
        <a href="#robot-programming">{content.robotProgramming.title}</a>
        <a href="#pricing">{content.pricing.title}</a>
      </nav>
      <a class="header-cta" href={contactUrl}>{content.ctaForm}</a>
    </header>

    <main>
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-media" aria-hidden="true">
          <img src={heroImage} alt="" width="1800" height="1100" loading="eager" />
        </div>
        <div class="hero-content">
          <h1 id="hero-title">{content.heroTitle}</h1>
          <p class="hero-lead">{content.heroSubtitle}</p>
          <p class="hero-copy">{content.intro}</p>
          <div class="hero-actions">
            <a class="button primary" href={contactUrl}>
              <span class="button-icon" set:html={iconMap.mail} />
              <span>{content.ctaForm}</span>
            </a>
            <a
              class="button secondary"
              href={lineUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="button-icon" set:html={iconMap.chat} />
              <span>{content.ctaLine}</span>
            </a>
          </div>
        </div>
      </section>

      <section class="language-bar" aria-label="Language switcher">
        {
          locales.map((alternateLocale) => (
            <a
              class:list={[alternateLocale === locale && "active"]}
              href={getLocalePath(alternateLocale)}
              aria-current={alternateLocale === locale ? "page" : undefined}
            >
              {localeLabels[alternateLocale]}
            </a>
          ))
        }
      </section>

      <section class="flow-section" aria-labelledby="flow-title">
        <div class="section-heading">
          <p>{content.learningFlowEyebrow}</p>
          <h2 id="flow-title">{content.learningFlowTitle}</h2>
          <span>{content.learningFlowDesc}</span>
        </div>
        <div class="flow-grid">
          {
            content.learningSteps.map((step, index) => (
              <article>
                <div class="step-shell">
                  <span class="step-number">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <span
                    class:list={["step-icon", `accent-${step.accent}`]}
                    set:html={getStepIcon(step.icon)}
                  />
                </div>
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="compare-section" aria-labelledby="compare-title">
        <div class="compare-copy">
          <p>Learning Fit</p>
          <h2 id="compare-title">{content.compareTitle}</h2>
        </div>
        <div class="compare-table" role="table" aria-label={content.compareTitle}>
          <div class="compare-row compare-head" role="row">
            <span role="columnheader">{content.compareBefore}</span>
            <span role="columnheader">{content.compareAfter}</span>
          </div>
          {
            content.compareBeforeItems.map((item, index) => (
              <div class="compare-row" role="row">
                <span role="cell">{item}</span>
                <span role="cell">{content.compareAfterItems[index]}</span>
              </div>
            ))
          }
        </div>
      </section>

      <section class="course-overview" aria-label="Courses">
        <div class="course-rail">
          {
            courseSections.map((section) => (
              <a href={`#${section.id}`}>
                <img
                  src={section.image}
                  alt=""
                  width="520"
                  height="360"
                  loading="lazy"
                />
                <span>{section.kicker}</span>
                <strong>{section.title}</strong>
              </a>
            ))
          }
        </div>
      </section>

      <section class="courses">
        {
          courseSections.map((section, index) => (
            <article
              class:list={["course-section", index % 2 === 1 && "reversed"]}
              id={section.id}
            >
              <figure class="course-image">
                <img
                  src={section.image}
                  alt={section.imageAlt}
                  width="1000"
                  height="700"
                  loading="lazy"
                />
              </figure>
              <div class="course-copy">
                <p class="section-number">{section.kicker}</p>
                <h2>{section.title}</h2>
                <p>{section.body}</p>
                {section.items && (
                  <div class="list-panel">
                    <h3>{section.listTitle}</h3>
                    <ul>
                      {section.items.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </div>
                )}
                {section.courses && (
                  <div class="course-cards">
                    {section.courses.map((course) => (
                      <div>
                        <h3>{course.title}</h3>
                        <p>{course.description}</p>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </article>
          ))
        }
      </section>

      <section class="pricing" id="pricing" aria-labelledby="pricing-title">
        <div class="section-heading compact">
          <p>Pricing</p>
          <h2 id="pricing-title">{content.pricing.title}</h2>
          <span>{content.pricing.body}</span>
        </div>
        <div class="pricing-grid">
          {
            content.pricing.items.map((item) => (
              <article>
                <span class="pricing-icon" set:html={getPricingIcon(item.icon)} />
                <h3>{item.label}</h3>
                <p class="price">{item.price}</p>
                <p>{item.note}</p>
              </article>
            ))
          }
        </div>
        <div class="pricing-cta">
          <div>
            <h3>{content.pricing.ctaHeading}</h3>
            <p>{content.pricing.ctaBody}</p>
          </div>
          <div class="hero-actions compact-actions">
            <a class="button secondary light" href={pricingUrl}>
              {content.pricing.ctaPricing}
            </a>
            <a class="button primary" href={contactUrl}>
              {content.pricing.ctaContact}
            </a>
          </div>
        </div>
      </section>

      <section class="final-cta" aria-labelledby="cta-title">
        <div>
          <h2 id="cta-title">{content.ctaHeading}</h2>
          <p>{content.ctaBody}</p>
        </div>
        <div class="hero-actions">
          <a class="button primary" href={contactUrl}>
            <span class="button-icon" set:html={iconMap.mail} />
            <span>{content.ctaForm}</span>
          </a>
          <a
            class="button secondary"
            href={lineUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="button-icon" set:html={iconMap.chat} />
            <span>{content.ctaLine}</span>
          </a>
        </div>
      </section>
    </main>

    <footer>
      <a href={acecoreOrigin}>Acecore</a>
      <span>Acecore Schools is managed as a dedicated Schools site.</span>
    </footer>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --page: #f6f8f4;
    --paper: #ffffff;
    --paper-soft: #eef6f2;
    --ink: #071f1d;
    --text: #18302c;
    --muted: #5b6d67;
    --line: rgba(7, 31, 29, 0.12);
    --brand: #006c63;
    --brand-deep: #00423d;
    --accent: #f3b83b;
    --teal-soft: #d9f0ea;
    --shadow: 0 24px 80px rgba(4, 39, 34, 0.12);
    font-family:
      Inter,
      "Noto Sans JP",
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    background: var(--page);
    color: var(--text);
    scroll-behavior: smooth;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    min-width: 320px;
    margin: 0;
    overflow-x: hidden;
    background: var(--page);
  }

  body {
    min-height: 100vh;
  }

  a {
    color: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 24px;
    align-items: center;
    min-height: 72px;
    border-bottom: 1px solid var(--line);
    padding: 0 max(20px, calc((100vw - 1180px) / 2));
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(18px);
  }

  .brand,
  .primary-nav,
  .hero-actions,
  .language-bar,
  footer {
    display: flex;
    align-items: center;
  }

  .brand {
    min-width: 0;
    gap: 10px;
    color: var(--ink);
    font-size: 1.05rem;
    font-weight: 900;
    text-decoration: none;
    white-space: nowrap;
  }

  .brand-mark {
    position: relative;
    display: grid;
    flex: 0 0 auto;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background:
      linear-gradient(135deg, transparent 53%, var(--accent) 54% 65%, transparent 66%),
      linear-gradient(135deg, var(--brand) 0 48%, transparent 49%);
    color: transparent;
    overflow: hidden;
  }

  .primary-nav {
    justify-content: center;
    gap: 6px;
  }

  .primary-nav a,
  .header-cta {
    border-radius: 8px;
    padding: 10px 12px;
    color: #25443f;
    font-size: 0.9rem;
    font-weight: 750;
    line-height: 1.2;
    text-decoration: none;
  }

  .primary-nav a:hover,
  .header-cta:hover {
    background: var(--paper-soft);
    color: var(--brand-deep);
  }

  .header-cta {
    justify-self: end;
    border: 1px solid rgba(0, 108, 99, 0.24);
    color: var(--brand);
  }

  .hero {
    position: relative;
    display: grid;
    align-items: center;
    min-height: clamp(580px, 78svh, 740px);
    overflow: hidden;
    padding: 104px max(20px, calc((100vw - 1180px) / 2)) 78px;
    isolation: isolate;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: -2;
    background: #e6efec;
  }

  .hero-media::after {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(90deg, rgba(246, 248, 244, 0.98) 0%, rgba(246, 248, 244, 0.88) 42%, rgba(246, 248, 244, 0.22) 74%, rgba(246, 248, 244, 0.08) 100%),
      linear-gradient(0deg, rgba(246, 248, 244, 1) 0%, rgba(246, 248, 244, 0) 24%);
    content: "";
  }

  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 68% 48%;
  }

  .hero-content {
    width: min(650px, 100%);
    min-width: 0;
  }

  h1 {
    max-width: 100%;
    color: var(--ink);
    font-size: clamp(3.3rem, 8vw, 6.4rem);
    font-weight: 950;
    line-height: 0.95;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .hero-lead {
    max-width: 720px;
    margin-top: 22px;
    color: var(--ink);
    font-size: clamp(1.25rem, 1.8vw, 1.78rem);
    font-weight: 850;
    line-height: 1.35;
    text-wrap: balance;
  }

  .hero-copy {
    max-width: 620px;
    margin-top: 18px;
    color: var(--muted);
    font-size: 1.04rem;
    line-height: 1.9;
    overflow-wrap: anywhere;
  }

  .hero-actions {
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    max-width: 100%;
    border: 1px solid transparent;
    border-radius: 8px;
    padding: 12px 18px;
    font-size: 0.94rem;
    font-weight: 850;
    line-height: 1.2;
    text-align: center;
    text-decoration: none;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      background 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button.primary {
    border-color: var(--brand);
    background: var(--brand);
    color: white;
    box-shadow: 0 16px 36px rgba(0, 108, 99, 0.22);
  }

  .button.secondary {
    border-color: rgba(0, 108, 99, 0.24);
    background: rgba(255, 255, 255, 0.9);
    color: var(--brand-deep);
  }

  .button.secondary.light {
    background: white;
  }

  .button-icon,
  .pricing-icon,
  .step-icon {
    display: inline-grid;
    place-items: center;
  }

  .button-icon {
    width: 18px;
    height: 18px;
    margin-right: 8px;
  }

  .button-icon :global(svg),
  .pricing-icon :global(svg),
  .step-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .button-icon :global(path),
  .pricing-icon :global(path),
  .step-icon :global(path) {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .language-bar {
    position: relative;
    z-index: 2;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    border-block: 1px solid var(--line);
    padding: 16px max(20px, calc((100vw - 1180px) / 2));
    background: var(--paper);
  }

  .language-bar a {
    min-height: 38px;
    border: 1px solid rgba(7, 31, 29, 0.1);
    border-radius: 8px;
    padding: 9px 13px;
    color: #4d625d;
    font-size: 0.88rem;
    font-weight: 750;
    line-height: 1.15;
    text-decoration: none;
    white-space: nowrap;
  }

  .language-bar a.active {
    border-color: var(--brand);
    background: var(--brand);
    color: white;
  }

  section {
    padding: 92px max(20px, calc((100vw - 1180px) / 2));
  }

  .section-heading {
    display: grid;
    gap: 14px;
    max-width: 770px;
    margin-bottom: 34px;
  }

  .section-heading p,
  .compare-copy p,
  .section-number {
    color: var(--brand);
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .section-heading h2,
  .compare-section h2,
  .course-copy h2,
  .pricing h2,
  .final-cta h2 {
    color: var(--ink);
    font-size: clamp(2.1rem, 4.2vw, 3.8rem);
    font-weight: 950;
    line-height: 1.05;
    letter-spacing: 0;
  }

  .section-heading span,
  .course-copy > p,
  .pricing .section-heading span,
  .final-cta p,
  .pricing-cta p {
    color: var(--muted);
    line-height: 1.85;
  }

  .flow-section {
    background:
      linear-gradient(180deg, rgba(217, 240, 234, 0.45), rgba(246, 248, 244, 0)),
      var(--page);
  }

  .flow-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--line);
    box-shadow: var(--shadow);
  }

  .flow-grid article {
    min-height: 250px;
    padding: 26px;
