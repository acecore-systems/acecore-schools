---
import {
  acecoreOrigin,
  lineUrl,
  schoolsContent,
  schoolsOrigin,
} from "../data/schools";
import { schoolsDetailContent } from "../data/schools-details";

const content = schoolsContent;
const detail = schoolsDetailContent;
const canonicalPath = "/";
const canonicalUrl = new URL(canonicalPath, schoolsOrigin).href;
const contactUrl = acecoreOrigin + "/contact/";
const pricingUrl = "#pricing";
const trialInquiryUrl = lineUrl;
const trialUrl = "#trial";

const mangaImages = {
  study: "/images/schools/manga-study.png",
  robot: "/images/schools/manga-robot.png",
  programming: "/images/schools/manga-programming.png",
  pc: "/images/schools/manga-pc-smartphone.png",
  ged: "/images/schools/manga-ged.png",
  consultation: "/images/schools/manga-consultation.png",
} as const;

const navItems = [
  { href: trialUrl, label: "無料体験" },
  { href: "#courses", label: "コース" },
  { href: "#schedule", label: "時間帯" },
  { href: pricingUrl, label: "料金" },
  { href: "#faq", label: "FAQ" },
];

const heroPanels = [
  {
    area: "panel-programming",
    image: mangaImages.programming,
    alt: "コードエディタと設計ノートの漫画調イラスト",
    label: "実践プログラミング",
    caption: "コードを書いて、仕組みをつくる。",
  },
  {
    area: "panel-robot",
    image: mangaImages.robot,
    alt: "ロボット工作キットとセンサー部品の漫画調イラスト",
    label: "ロボット工作・制御",
    caption: "組み立てて、動かして、考える。",
  },
  {
    area: "panel-pc",
    image: mangaImages.pc,
    alt: "スマートフォンとパソコン操作の漫画調イラスト",
    label: "パソコン/スマホ",
    caption: "基本操作から活用まで。",
  },
  {
    area: "panel-ged",
    image: mangaImages.ged,
    alt: "高卒認定の学習教材と計画表の漫画調イラスト",
    label: "高卒認定",
    caption: "未来の選択肢を、しっかり広げる。",
  },
  {
    area: "panel-study",
    image: mangaImages.study,
    alt: "学習ノートと教材の漫画調イラスト",
    label: "学習塾",
    caption: "基礎から応用まで、一人ひとりに合わせる。",
  },
  {
    area: "panel-consultation",
    image: mangaImages.consultation,
    alt: "相談シートと学習計画を作る漫画調イラスト",
    label: "まずは相談から",
    caption: "毎週の学びの快適さを一緒に描きます。",
  },
];

const courseSections = [
  {
    id: "juku",
    number: "01",
    tone: "#0f4d8b",
    title: content.juku.title,
    body: "基礎学力から応用まで、一人ひとりに合わせた学習をサポート。",
    image: mangaImages.study,
    imageAlt: "学習ノートと教材",
    items: content.juku.features.slice(0, 2),
  },
  {
    id: "robot-control",
    number: "02",
    tone: "#e06e00",
    title: content.robotProgramming.title,
    body: "センサーやモーターを使い、組み立てて動かす制御の仕組みを学ぶ。",
    image: mangaImages.robot,
    imageAlt: "ロボット工作キット",
    items: content.robotProgramming.courses.map((course) => course.title),
  },
  {
    id: "practical-programming",
    number: "03",
    tone: "#0f4d8b",
    title: content.practicalProgramming.title,
    body: "Web・アプリ開発、Git、API、データベース、クラウドまで実践的に学ぶ。",
    image: mangaImages.programming,
    imageAlt: "コードエディタと設計ノート",
    items: content.practicalProgramming.contents.slice(0, 3),
  },
  {
    id: "pc-smartphone",
    number: "04",
    tone: "#d9473d",
    title: content.pcSmartphone.title,
    body: "基本操作から仕事や日常で役立つ活用まで、やさしく丁寧にサポート。",
    image: mangaImages.pc,
    imageAlt: "スマートフォンとパソコン",
    items: content.pcSmartphone.levels.slice(0, 3),
  },
  {
    id: "ged",
    number: "05",
    tone: "#6b3aa0",
    title: content.ged.title,
    body: "高卒認定試験の学習を個別に合わせて、しっかりサポート。",
    image: mangaImages.ged,
    imageAlt: "高卒認定の教材",
    items: content.ged.supports.slice(0, 3),
  },
];

const learningSteps = [
  {
    number: "1",
    title: "発見",
    icon: "search",
    body: "興味を見つける。やりたいことを明確にする。",
  },
  {
    number: "2",
    title: "理解",
    icon: "book",
    body: "体験して理解する。小さな成功体験で自信をつくる。",
  },
  {
    number: "3",
    title: "応用",
    icon: "code",
    body: "できることが増える。スキルを組み上げて応用の幅を広げる。",
  },
  {
    number: "4",
    title: "定着",
    icon: "target",
    body: "生活で活かす。学んだことを日常や将来に活かす。",
  },
] as const;

const targetAudiences = [
  "高校生",
  "保護者の方",
  "社会人・大人の学び直し",
  "シニア・PC/スマホ初心者",
  "高卒認定を目指す方",
];

const iconMap = {
  search: `<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="10.5" cy="10.5" r="6.5"/><path d="m15.5 15.5 4 4"/></svg>`,
  book: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5.5c2.7 0 5.2.45 8 2.4 2.8-1.95 5.3-2.4 8-2.4v13c-2.7 0-5.2.45-8 2.4-2.8-1.95-5.3-2.4-8-2.4z"/><path d="M12 7.9v13"/></svg>`,
  code: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 8-4 4 4 4M15 8l4 4-4 4"/></svg>`,
  target: `<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="4"/><path d="M12 2v4M12 18v4M2 12h4M18 12h4"/></svg>`,
  calendar: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 5.5h14v14H5z"/><path d="M8 3.5v4M16 3.5v4M5 10h14"/></svg>`,
  wallet: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4.5 7.5h15v11h-15z"/><path d="M6.5 7.5V5.8l10-1.7v3.4"/><path d="M15.5 13h4"/></svg>`,
  bookOpen: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5.5h6.5A3.5 3.5 0 0 1 14 9v10a3.5 3.5 0 0 0-3.5-3.5H4z"/><path d="M20 5.5h-6.5A3.5 3.5 0 0 0 10 9v10a3.5 3.5 0 0 1 3.5-3.5H20z"/></svg>`,
};

const getPricingIcon = (icon: string) => {
  if (icon === "calendar-days") return iconMap.calendar;
  if (icon === "book-open") return iconMap.bookOpen;
  return iconMap.wallet;
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "EducationalOrganization",
      name: "Acecore Schools",
      description: content.description,
      url: canonicalUrl,
      parentOrganization: {
        "@type": "Organization",
        name: "Acecore",
        url: acecoreOrigin,
      },
    },
    ...courseSections.map((section) => ({
      "@type": "Course",
      name: section.title,
      description: section.body,
      provider: { "@type": "EducationalOrganization", name: "Acecore Schools" },
      url: `${canonicalUrl}#${section.id}`,
    })),
    {
      "@type": "FAQPage",
      mainEntity: detail.faqs.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ],
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{content.title} | Acecore</title>
    <meta name="description" content={content.description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={`${content.title} | Acecore`} />
    <meta property="og:description" content={content.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta
      property="og:image"
      content={new URL(mangaImages.consultation, schoolsOrigin).href}
    />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={canonicalPath} aria-label="Acecore Schools">
        <span>Acecore Schools</span>
      </a>
      <nav class="primary-nav" aria-label="School sections">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
      <a
        class="header-cta"
        href={trialInquiryUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="line-badge" aria-hidden="true">LINE</span>
        <span>LINEで無料体験を相談する</span>
        <span aria-hidden="true">›</span>
      </a>
    </header>

    <main class="comic-page">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy panel panel-hero-copy">
          <div class="speed-lines" aria-hidden="true"></div>
          <h1 id="hero-title">{content.heroTitle}</h1>
          <p class="hero-lead">
            一人ひとりに合わせたサポートで、ITを「わかる」から「できる」へ。
          </p>
          <p class="hero-body">
            あなたのペースに合わせた学びの設計で、一緒に選び、進め、未来につなげます。
          </p>
          <div class="hero-actions">
            <a
              class="button button-line"
              href={trialInquiryUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="line-badge" aria-hidden="true">LINE</span>
              <span>{detail.trial.primaryCta}</span>
            </a>
            <a class="button button-plain" href={pricingUrl}>
              <span>{detail.trial.secondaryCta}</span>
              <span aria-hidden="true">›</span>
            </a>
          </div>
        </div>

        <div class="hero-board" aria-label="Acecore Schoolsの学びのコマ">
          {
            heroPanels.map((heroPanel) => (
              <article class:list={["manga-panel", heroPanel.area]}>
                <img
                  src={heroPanel.image}
                  alt={heroPanel.alt}
                  width="1536"
                  height="1024"
                  loading="eager"
                  fetchpriority="high"
                />
                <div class="panel-caption">
                  <strong>{heroPanel.label}</strong>
                  <span>{heroPanel.caption}</span>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="sheet-grid" aria-label="Acecore Schools details">
        <section
          class="panel trial-panel"
          id="trial"
          aria-labelledby="trial-title"
        >
          <header class="panel-heading">
            <span class="panel-number">01</span>
            <h2 id="trial-title">無料体験</h2>
          </header>
          <p>まずは相談から。学びの地図を一緒に描きます。</p>
          <ul class="check-list">
            <li>ヒアリング</li>
            <li>体験レッスン</li>
            <li>学習プラン提案</li>
          </ul>
          <figure class="panel-figure">
            <img
              src={mangaImages.consultation}
              alt="無料体験の相談シート"
              width="1536"
              height="1024"
              loading="lazy"
            />
          </figure>
          <p class="small-note">所要時間: 約60分</p>
        </section>

        <section class="panel flow-panel" aria-labelledby="flow-title">
          <header class="panel-heading">
            <span class="panel-number">02</span>
            <h2 id="flow-title">学びの流れ</h2>
            <small>4つのステップ</small>
          </header>
          <div class="flow-list">
            {
              learningSteps.map((step) => (
                <article class="flow-step">
                  <span class="step-number">{step.number}</span>
                  <span class="step-icon" set:html={iconMap[step.icon]} />
                  <h3>{step.title}</h3>
                  <p>{step.body}</p>
                </article>
              ))
            }
          </div>
        </section>

        <section
          class="panel courses-panel"
          id="courses"
          aria-labelledby="courses-title"
        >
          <header class="panel-heading">
            <span class="panel-number">03</span>
            <h2 id="courses-title">コース一覧</h2>
            <small>目的に合わせて選べる5つのコース</small>
          </header>
          <div class="course-grid">
            {
              courseSections.map((section) => (
                <article
                  class="course-card"
                  id={section.id}
                  style={`--course-tone: ${section.tone}`}
                >
                  <span class="course-kicker">
                    {section.number} {section.title}
                  </span>
                  <figure>
                    <img
                      src={section.image}
                      alt={section.imageAlt}
                      width="1536"
                      height="1024"
                      loading="lazy"
                    />
                  </figure>
                  <p>{section.body}</p>
                </article>
              ))
            }
          </div>
        </section>

        <section class="panel compare-panel" aria-labelledby="compare-title">
          <header class="panel-heading">
            <span class="panel-number">04</span>
            <h2 id="compare-title">独学とAcecore Schoolsの比較</h2>
          </header>
          <div class="compare-grid">
            <div>
              <h3>{content.compareBefore}</h3>
              <ul>
                {
                  content.compareBeforeItems.map((item) => (
                    <li>
                      <span aria-hidden="true">×</span>
                      <strong>{item}</strong>
                    </li>
                  ))
                }
              </ul>
            </div>
            <span class="versus" aria-hidden="true">VS</span>
            <div>
              <h3>{content.compareAfter}</h3>
              <ul>
                {
                  content.compareAfterItems.map((item) => (
                    <li>
                      <span aria-hidden="true">✓</span>
                      <strong>{item}</strong>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </section>

        <section
          class="panel schedule-panel"
          id="schedule"
          aria-labelledby="schedule-title"
        >
          <header class="panel-heading">
            <span class="panel-number">05</span>
            <h2 id="schedule-title">時間帯</h2>
            <small>開校時間・利用可能時間</small>
          </header>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>{detail.schedule.dayLabel}</th>
                  <th>{detail.schedule.timeLabel}</th>
                  <th>{detail.schedule.noteLabel}</th>
                </tr>
              </thead>
              <tbody>
                {
                  detail.schedule.items.map((item) => (
                    <tr>
                      <td>{item.day}</td>
                      <td>{item.time}</td>
                      <td>{item.note}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
          <p class="small-note">{detail.schedule.note}</p>
        </section>

        <section
          class="panel pricing-panel"
          id="pricing"
          aria-labelledby="pricing-title"
        >
          <header class="panel-heading">
            <span class="panel-number">06</span>
            <h2 id="pricing-title">料金の目安</h2>
            <small>ガイド</small>
          </header>
          <div class="price-list">
            {
              content.pricing.items.map((item) => (
                <article>
                  <span
                    class="price-icon"
                    set:html={getPricingIcon(item.icon)}
                  />
                  <h3>{item.label}</h3>
                  <strong>{item.price}</strong>
                </article>
              ))
            }
          </div>
          <p class="small-note">
            料金は目安です。詳細は無料体験時にご案内します。
          </p>
        </section>

        <section class="panel faq-panel" id="faq" aria-labelledby="faq-title">
          <header class="panel-heading">
            <span class="panel-number">07</span>
            <h2 id="faq-title">FAQ</h2>
            <small>よくあるご質問</small>
          </header>
          <div class="faq-list">
            {
              detail.faqs.slice(0, 5).map((item) => (
                <details>
                  <summary>{item.question}</summary>
                  <p>{item.answer}</p>
                </details>
              ))
            }
          </div>
        </section>

        <section class="panel audience-panel" aria-labelledby="audience-title">
          <header class="panel-heading">
            <span class="panel-number">08</span>
            <h2 id="audience-title">対象となる方</h2>
          </header>
          <ul class="audience-list">
            {targetAudiences.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="final-panel" aria-labelledby="final-title">
          <div class="final-copy">
            <span class="panel-number">09</span>
            <h2 id="final-title">次の一歩を、ここから。</h2>
            <p>
              あなた専用の学びのプランで、「できる！」を増やしていきましょう。
            </p>
          </div>
          <div class="final-strip-images" aria-hidden="true">
            <img
              src={mangaImages.robot}
              alt=""
              width="1536"
              height="1024"
              loading="lazy"
            />
            <img
              src={mangaImages.programming}
              alt=""
              width="1536"
              height="1024"
              loading="lazy"
            />
            <img
              src={mangaImages.study}
              alt=""
              width="1536"
              height="1024"
              loading="lazy"
            />
          </div>
          <a
            class="final-cta"
            href={trialInquiryUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="line-badge" aria-hidden="true">LINE</span>
            <span>{detail.finalCta.primary}</span>
            <span aria-hidden="true">›</span>
          </a>
        </section>
      </section>
    </main>

    <footer class="site-footer">
      <a href={acecoreOrigin}>Acecore</a>
      <nav aria-label="Footer navigation">
        <a href={contactUrl}>{content.ctaForm}</a>
        <a href={pricingUrl}>{detail.trial.secondaryCta}</a>
        <a href={trialInquiryUrl}>LINE</a>
      </nav>
    </footer>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --paper: #ffffff;
    --ink: #080b0d;
    --navy: #073b78;
    --green: #009f3a;
    --green-dark: #007d2e;
    --red: #d94135;
    --muted: #4f5961;
    --line: #0a0d0f;
    --panel-gap: 6px;
    font-family:
      "Arial",
      "Noto Sans JP",
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    background: var(--paper);
    color: var(--ink);
    scroll-behavior: smooth;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    min-width: 320px;
    margin: 0;
    background: var(--paper);
  }

  body {
    overflow-x: hidden;
  }

  a {
    color: inherit;
  }

  img,
  svg {
    display: block;
  }

  img {
    max-width: 100%;
  }

  h1,
  h2,
  h3,
  p,
  figure {
    margin: 0;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    display: grid;
    grid-template-columns: minmax(180px, 1fr) auto minmax(210px, 1fr);
    gap: 24px;
    align-items: center;
    min-height: 58px;
    border-bottom: 3px solid var(--line);
    padding: 0 24px;
    background: #fff;
  }

  .brand,
  .site-footer a {
    text-decoration: none;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    color: var(--ink);
    font-size: 1.7rem;
    font-weight: 950;
    line-height: 1;
  }

  .brand-mark {
    position: relative;
    width: 30px;
    height: 30px;
    border: 3px solid var(--ink);
    transform: rotate(30deg);
  }

  .brand-mark::before,
  .brand-mark::after {
    position: absolute;
    inset: 5px;
    border: 2px solid var(--ink);
    content: "";
  }

  .brand-mark::after {
    inset: auto;
    top: -3px;
    bottom: -3px;
    left: 50%;
    width: 2px;
    border: 0;
    background: var(--ink);
    transform: translateX(-50%);
  }

  .primary-nav {
    display: flex;
    gap: clamp(16px, 2.2vw, 36px);
    align-items: center;
    justify-content: center;
  }

  .primary-nav a {
    font-size: 1rem;
    font-weight: 950;
    text-decoration: none;
    white-space: nowrap;
  }

  .header-cta,
  .button,
  .final-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    max-width: 100%;
    min-height: 46px;
    border: 2px solid var(--line);
    border-radius: 5px;
    padding: 11px 18px;
    font-size: 0.95rem;
    font-weight: 950;
    line-height: 1.15;
    text-decoration: none;
  }

  .header-cta {
    justify-self: end;
    gap: 8px;
    border-color: var(--green-dark);
    background: var(--green);
    color: white;
    box-shadow: inset 0 -2px 0 rgba(0, 0, 0, 0.16);
    white-space: nowrap;
  }

  .line-badge {
    display: inline-grid;
    flex: 0 0 auto;
    place-items: center;
    min-width: 38px;
    height: 26px;
    border-radius: 999px;
    background: white;
    color: var(--green);
    font-size: 0.7rem;
    font-weight: 950;
    line-height: 1;
  }

  .comic-page {
    width: min(1540px, 100%);
    border-right: 3px solid var(--line);
    border-left: 3px solid var(--line);
    margin: 0 auto;
    background: var(--line);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(330px, 0.35fr) minmax(0, 0.65fr);
    gap: var(--panel-gap);
    background: var(--line);
