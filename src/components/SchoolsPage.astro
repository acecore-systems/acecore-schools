---
import {
  acecoreOrigin,
  defaultLocale,
  getLocalePath,
  getLocalizedAcecoreUrl,
  htmlLangMap,
  lineUrl,
  localeLabels,
  locales,
  schoolsContent,
  schoolsOrigin,
  type Locale,
} from "../data/schools";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = schoolsContent[locale] ?? schoolsContent[defaultLocale];
const canonicalPath = getLocalePath(locale);
const canonicalUrl = new URL(canonicalPath, schoolsOrigin).href;
const pricingUrl = getLocalizedAcecoreUrl(locale, "/pricing/");
const contactUrl = getLocalizedAcecoreUrl(locale, "/contact/");

const heroImage =
  "https://images.unsplash.com/photo-1509062522246-3755977927d7?w=1600&h=900&fit=crop&q=82&fm=webp";
const jukuImage =
  "https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=1000&h=625&fit=crop&q=82&fm=webp";
const programmingImage =
  "https://images.unsplash.com/photo-1488590528505-98d2b5aba04b?w=1000&h=625&fit=crop&q=82&fm=webp";
const pcImage =
  "https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=1000&h=625&fit=crop&q=82&fm=webp";

const courseSections = [
  {
    id: "juku",
    kicker: "01",
    title: content.juku.title,
    body: content.juku.desc,
    image: jukuImage,
    imageAlt: content.juku.imgAlt,
    listTitle: content.juku.featuresLabel,
    items: content.juku.features,
  },
  {
    id: "robot-programming",
    kicker: "02",
    title: content.robotProgramming.title,
    body: content.robotProgramming.desc,
    image: programmingImage,
    imageAlt: content.robotProgramming.progImgAlt,
    courses: content.robotProgramming.courses,
  },
  {
    id: "practical-programming",
    kicker: "03",
    title: content.practicalProgramming.title,
    body: content.practicalProgramming.desc,
    listTitle: content.practicalProgramming.contentsLabel,
    items: content.practicalProgramming.contents,
  },
  {
    id: "pc-smartphone",
    kicker: "04",
    title: content.pcSmartphone.title,
    body: content.pcSmartphone.desc,
    image: pcImage,
    imageAlt: content.pcSmartphone.imgAlt,
    listTitle: content.pcSmartphone.levelsLabel,
    items: content.pcSmartphone.levels,
  },
  {
    id: "ged",
    kicker: "05",
    title: content.ged.title,
    body: content.ged.desc,
    listTitle: content.ged.supportLabel,
    items: content.ged.supports,
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "EducationalOrganization",
      name: "Acecore Schools",
      description: content.description,
      url: canonicalUrl,
      parentOrganization: {
        "@type": "Organization",
        name: "Acecore",
        url: acecoreOrigin,
      },
    },
    ...courseSections.map((section) => ({
      "@type": "Course",
      name: section.title,
      description: section.body,
      provider: { "@type": "EducationalOrganization", name: "Acecore Schools" },
      url: `${canonicalUrl}#${section.id}`,
    })),
  ],
};
---

<!doctype html>
<html lang={htmlLangMap[locale]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{content.title} | Acecore</title>
    <meta name="description" content={content.description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={`${content.title} | Acecore`} />
    <meta property="og:description" content={content.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={heroImage} />
    <meta name="twitter:card" content="summary_large_image" />
    {
      locales.map((alternateLocale) => (
        <link
          rel="alternate"
          hreflang={htmlLangMap[alternateLocale]}
          href={new URL(getLocalePath(alternateLocale), schoolsOrigin).href}
        />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={`${schoolsOrigin}/`} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={canonicalPath} aria-label="Acecore Schools">
        <span class="brand-mark">A</span>
        <span>Acecore Schools</span>
      </a>
      <nav class="primary-nav" aria-label="School sections">
        <a href="#juku">{content.juku.title}</a>
        <a href="#robot-programming">{content.robotProgramming.title}</a>
        <a href="#pricing">{content.pricing.title}</a>
      </nav>
      <a class="header-cta" href={contactUrl}>{content.ctaForm}</a>
    </header>

    <main>
      <section class="hero">
        <div class="hero-media" aria-hidden="true">
          <img
            src={heroImage}
            alt=""
            width="1600"
            height="900"
            loading="eager"
          />
        </div>
        <div class="hero-content">
          <p class="eyebrow">Acecore Schools</p>
          <h1>{content.heroTitle}</h1>
          <p class="hero-lead">{content.heroSubtitle}</p>
          <p class="hero-copy">{content.intro}</p>
          <div class="hero-actions">
            <a class="button primary" href={contactUrl}>{content.ctaForm}</a>
            <a
              class="button secondary"
              href={lineUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              {content.ctaLine}
            </a>
          </div>
        </div>
      </section>

      <section class="language-bar" aria-label="Language switcher">
        {
          locales.map((alternateLocale) => (
            <a
              class:list={[alternateLocale === locale && "active"]}
              href={getLocalePath(alternateLocale)}
              aria-current={alternateLocale === locale ? "page" : undefined}
            >
              {localeLabels[alternateLocale]}
            </a>
          ))
        }
      </section>

      <section class="flow-section" aria-labelledby="flow-title">
        <div class="section-heading">
          <p>{content.learningFlowEyebrow}</p>
          <h2 id="flow-title">{content.learningFlowTitle}</h2>
          <span>{content.learningFlowDesc}</span>
        </div>
        <div class="flow-grid">
          {
            content.learningSteps.map((step, index) => (
              <article>
                <span class="step-number">
                  {String(index + 1).padStart(2, "0")}
                </span>
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="compare-section" aria-labelledby="compare-title">
        <div>
          <p class="eyebrow dark">Learning Fit</p>
          <h2 id="compare-title">{content.compareTitle}</h2>
        </div>
        <div class="compare-grid">
          <article>
            <h3>{content.compareBefore}</h3>
            <ul>
              {content.compareBeforeItems.map((item) => <li>{item}</li>)}
            </ul>
          </article>
          <article class="highlight">
            <h3>{content.compareAfter}</h3>
            <ul>
              {content.compareAfterItems.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </div>
      </section>

      <section class="courses" aria-label="Courses">
        {
          courseSections.map((section, index) => (
            <article
              class:list={[
                "course-section",
                index % 2 === 1 && "reversed",
                !section.image && "text-only",
              ]}
              id={section.id}
            >
              <div class="course-copy">
                <p class="section-number">{section.kicker}</p>
                <h2>{section.title}</h2>
                <p>{section.body}</p>
                {section.items && (
                  <div class="list-panel">
                    <h3>{section.listTitle}</h3>
                    <ul>
                      {section.items.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </div>
                )}
                {section.courses && (
                  <div class="course-cards">
                    {section.courses.map((course) => (
                      <div>
                        <h3>{course.title}</h3>
                        <p>{course.description}</p>
                      </div>
                    ))}
                  </div>
                )}
              </div>
              {section.image && (
                <figure class="course-image">
                  <img
                    src={section.image}
                    alt={section.imageAlt}
                    width="1000"
                    height="625"
                    loading="lazy"
                  />
                </figure>
              )}
            </article>
          ))
        }
      </section>

      <section class="pricing" id="pricing" aria-labelledby="pricing-title">
        <div class="section-heading compact">
          <p>Pricing</p>
          <h2 id="pricing-title">{content.pricing.title}</h2>
          <span>{content.pricing.body}</span>
        </div>
        <div class="pricing-grid">
          {
            content.pricing.items.map((item) => (
              <article>
                <h3>{item.label}</h3>
                <p class="price">{item.price}</p>
                <p>{item.note}</p>
              </article>
            ))
          }
        </div>
        <div class="pricing-cta">
          <div>
            <h3>{content.pricing.ctaHeading}</h3>
            <p>{content.pricing.ctaBody}</p>
          </div>
          <div class="hero-actions compact-actions">
            <a class="button secondary" href={pricingUrl}
              >{content.pricing.ctaPricing}</a
            >
            <a class="button primary" href={contactUrl}
              >{content.pricing.ctaContact}</a
            >
          </div>
        </div>
      </section>

      <section class="final-cta" aria-labelledby="cta-title">
        <h2 id="cta-title">{content.ctaHeading}</h2>
        <p>{content.ctaBody}</p>
        <div class="hero-actions">
          <a class="button primary" href={contactUrl}>{content.ctaForm}</a>
          <a
            class="button secondary"
            href={lineUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            {content.ctaLine}
          </a>
        </div>
      </section>
    </main>

    <footer>
      <a href={acecoreOrigin}>Acecore</a>
      <span>Acecore Schools is managed as a dedicated Schools site.</span>
    </footer>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    font-family:
      Inter,
      "Noto Sans JP",
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    background: #f7f8f4;
    color: #17201a;
    scroll-behavior: smooth;
    overflow-x: hidden;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: #f7f8f4;
    overflow-x: hidden;
  }

  a {
    color: inherit;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 20px;
    align-items: center;
    min-height: 72px;
    border-bottom: 1px solid rgba(23, 32, 26, 0.1);
    padding: 0 max(20px, calc((100vw - 1180px) / 2));
    background: rgba(247, 248, 244, 0.92);
    backdrop-filter: blur(14px);
  }

  .brand,
  .primary-nav,
  .hero-actions,
  .language-bar,
  footer {
    display: flex;
    align-items: center;
  }

  .brand {
    gap: 10px;
    font-weight: 800;
    text-decoration: none;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: #14532d;
    color: white;
  }

  .primary-nav {
    justify-content: center;
    gap: 18px;
    font-size: 0.92rem;
  }

  .primary-nav a,
  .header-cta {
    text-decoration: none;
  }

  .header-cta {
    justify-self: end;
    font-weight: 800;
    color: #0f766e;
  }

  .hero {
    position: relative;
    display: grid;
    align-items: end;
    min-height: min(760px, calc(100vh - 48px));
    overflow: hidden;
    padding: 120px max(20px, calc((100vw - 1180px) / 2)) 72px;
    color: white;
  }

  .hero-media {
    position: absolute;
    inset: 0;
  }

  .hero-media::after {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(10, 27, 19, 0.84),
      rgba(10, 27, 19, 0.28)
    );
    content: "";
  }

  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-content {
    position: relative;
    width: min(760px, 100%);
    min-width: 0;
    max-width: 760px;
  }

  .eyebrow,
  .section-heading p,
  .section-number {
    margin: 0 0 12px;
    color: #5eead4;
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .eyebrow.dark,
  .section-number {
    color: #0f766e;
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  h1 {
    max-width: 100%;
    font-size: clamp(3rem, 7vw, 6.6rem);
    line-height: 0.92;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .hero-lead {
    max-width: 100%;
    margin-top: 18px;
    font-size: clamp(1.25rem, 2.4vw, 2rem);
    font-weight: 700;
    overflow-wrap: anywhere;
  }

  .hero-copy {
    max-width: 690px;
    margin-top: 18px;
    color: rgba(255, 255, 255, 0.86);
    font-size: 1.04rem;
    line-height: 1.85;
    overflow-wrap: anywhere;
  }

  .hero-actions {
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .button {
    min-height: 46px;
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 8px;
    padding: 12px 18px;
    font-weight: 800;
    text-decoration: none;
  }

  .button.primary {
    border-color: #14532d;
    background: #14532d;
    color: white;
  }

  .button.secondary {
    background: rgba(255, 255, 255, 0.9);
    color: #17201a;
  }

  .language-bar {
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    border-bottom: 1px solid rgba(23, 32, 26, 0.1);
    padding: 18px 20px;
    background: white;
  }

  .language-bar a {
    border-radius: 999px;
    padding: 8px 12px;
    color: #46554b;
    font-size: 0.9rem;
    text-decoration: none;
  }

  .language-bar a.active {
    background: #14532d;
    color: white;
  }

  section {
    padding: 82px max(20px, calc((100vw - 1180px) / 2));
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: 32px;
  }

  .section-heading h2,
  .compare-section h2,
  .course-copy h2,
  .pricing h2,
  .final-cta h2 {
    color: #10251c;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: 0;
  }

  .section-heading span,
  .course-copy > p,
  .pricing .section-heading span,
  .final-cta p {
    display: block;
    margin-top: 16px;
    color: #526056;
    line-height: 1.8;
  }

  .flow-grid,
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  .flow-grid article,
  .pricing-grid article,
  .compare-grid article,
  .list-panel,
  .course-cards > div,
  .pricing-cta {
    border: 1px solid #d8dfd8;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.82);
  }

  .flow-grid article {
    min-height: 210px;
    padding: 22px;
  }

  .step-number {
    color: #0f766e;
    font-weight: 900;
  }

  .flow-grid h3,
  .pricing-grid h3,
  .course-cards h3 {
    margin: 12px 0 10px;
    color: #10251c;
  }

  .flow-grid p,
  .pricing-grid p,
  .compare-grid li,
  .list-panel li,
  .course-cards p {
    color: #56625a;
    line-height: 1.7;
  }

  .compare-section {
    display: grid;
    grid-template-columns: 0.7fr 1.3fr;
    gap: 28px;
    background: #edf2ec;
  }

  .compare-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .compare-grid article {
    padding: 24px;
  }

  .compare-grid article.highlight {
    border-color: #14532d;
    background: #f8fbf7;
  }

  ul {
    margin: 14px 0 0;
    padding: 0;
    list-style: none;
  }

  li + li {
    margin-top: 9px;
  }

  li::before {
    margin-right: 8px;
    color: #0f766e;
    font-weight: 900;
    content: "•";
  }

  .courses {
    display: grid;
    gap: 72px;
  }

  .course-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.86fr);
    gap: 36px;
    align-items: center;
    padding: 0;
    scroll-margin-top: 96px;
  }

  .course-section.text-only {
    grid-template-columns: minmax(0, 1fr);
  }

  .course-section.reversed {
    grid-template-columns: minmax(320px, 0.86fr) minmax(0, 1fr);
  }

  .course-section.reversed .course-copy {
    order: 2;
  }

  .course-copy {
    min-width: 0;
  }

  .list-panel,
  .course-cards > div {
    margin-top: 22px;
    padding: 20px;
  }

  .course-cards {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }

  .course-image {
    margin: 0;
    overflow: hidden;
    border-radius: 8px;
    background: #dbe4dc;
    aspect-ratio: 16 / 10;
  }

  .course-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pricing {
    background: #ffffff;
    scroll-margin-top: 96px;
  }

  .section-heading.compact {
    margin-inline: auto;
    text-align: center;
  }

  .pricing-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .pricing-grid article {
    min-height: 190px;
    padding: 24px;
  }

  .price {
    margin: 10px 0;
    color: #10251c !important;
    font-size: 1.7rem;
    font-weight: 900;
  }

  .pricing-cta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    margin-top: 16px;
    padding: 24px;
    background: #eef7ef;
  }

  .compact-actions {
    margin-top: 0;
  }

  .final-cta {
    background: #10251c;
    color: white;
    text-align: center;
  }

  .final-cta p {
    max-width: 700px;
    margin-inline: auto;
    color: rgba(255, 255, 255, 0.78);
  }

  .final-cta .hero-actions {
    justify-content: center;
  }

  footer {
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px 18px;
    padding: 28px 20px;
    color: #607066;
    font-size: 0.9rem;
  }

  @media (max-width: 900px) {
    .site-header {
      grid-template-columns: 1fr auto;
      gap: 12px;
      overflow: hidden;
      padding: 0 16px;
    }

    .header-cta {
      max-width: calc(100vw - 86px);
      font-size: 0.95rem;
      line-height: 1.2;
      overflow-wrap: anywhere;
      text-align: right;
    }

    .primary-nav {
      display: none;
    }

    .hero {
      min-height: 680px;
      padding: 96px 20px 56px;
    }

    section {
      padding: 64px 20px;
    }

    .flow-grid,
    .pricing-grid,
    .compare-section,
    .compare-grid,
    .course-section,
    .course-section.reversed {
      grid-template-columns: 1fr;
    }

    .course-section.reversed .course-copy {
      order: 0;
    }

    .pricing-cta {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 560px) {
    .brand span:last-child {
      display: none;
    }

    .site-header {
      grid-template-columns: auto minmax(0, 1fr);
    }

    .header-cta {
      justify-self: start;
      max-width: 100%;
      text-align: left;
    }

    .hero-content {
      max-width: min(350px, 100%);
    }

    h1 {
      font-size: clamp(2.5rem, 16vw, 4.2rem);
    }

    .button {
      width: 100%;
      text-align: center;
    }

    .hero-actions {
      width: 100%;
    }

    .hero-lead {
      max-width: min(350px, 100%);
      line-height: 1.35;
      word-break: break-all;
    }

    .hero-copy {
      max-width: min(350px, 100%);
      word-break: break-all;
    }

    .language-bar {
      justify-content: flex-start;
      flex-wrap: nowrap;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .language-bar::-webkit-scrollbar {
      display: none;
    }

    .language-bar a {
      flex: 0 0 auto;
      white-space: nowrap;
    }
  }
</style>
