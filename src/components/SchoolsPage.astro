---
import {
  acecoreOrigin,
  lineUrl,
  schoolsContent,
  schoolsOrigin,
} from "../data/schools";

const content = schoolsContent;
const canonicalPath = "/";
const canonicalUrl = new URL(canonicalPath, schoolsOrigin).href;
const contactUrl = "/contact/";

const heroImage = "/images/schools/hero-workshop.webp";
const jukuImage = "/images/schools/course-tutoring.webp";
const robotImage = "/images/schools/course-robot.webp";
const programmingImage = "/images/schools/course-programming.webp";
const pcImage = "/images/schools/course-pc-smartphone.webp";
const gedImage = "/images/schools/course-ged.webp";
const ctaImage = "/images/schools/cta-consultation.webp";

const heroKicker = "つくる。理解する。未来につなげる。";
const detailLabel = "詳しく見る";
const scrollLabel = "Scroll";
const languageLabels = [
  "日本語",
  "English",
  "简体中文",
  "Español",
  "Português",
  "Français",
  "한국어",
  "Deutsch",
  "Русский",
];

const iconMap = {
  globe: `<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8.5"/><path d="M3.5 12h17M12 3.5c2.2 2.25 3.3 5.08 3.3 8.5s-1.1 6.25-3.3 8.5M12 3.5C9.8 5.75 8.7 8.58 8.7 12s1.1 6.25 3.3 8.5"/></svg>`,
  mail: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4.5 6.5h15v11h-15z"/><path d="m5 7 7 6 7-6"/></svg>`,
  chat: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 6.75c0-1.24 1.01-2.25 2.25-2.25h9.5c1.24 0 2.25 1.01 2.25 2.25v6.5c0 1.24-1.01 2.25-2.25 2.25h-4.5L8 19.5v-4H7.25C6.01 15.5 5 14.49 5 13.25z"/><path d="M8.5 9.5h7M8.5 12.25h4.75"/></svg>`,
  sparkles: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 3 1.7 5.2L19 10l-5.3 1.8L12 17l-1.7-5.2L5 10l5.3-1.8z"/><path d="m18.5 15 .8 2.2 2.2.8-2.2.8-.8 2.2-.8-2.2-2.2-.8 2.2-.8z"/></svg>`,
  bot: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 8.5h8a3 3 0 0 1 3 3v5a3 3 0 0 1-3 3H8a3 3 0 0 1-3-3v-5a3 3 0 0 1 3-3Z"/><path d="M12 8.5V5M9 5h6M9.25 13h.01M14.75 13h.01M9 16h6"/></svg>`,
  code: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 8-4 4 4 4M15 8l4 4-4 4"/><path d="m13 6-2 12"/></svg>`,
  flag: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 21V4.5"/><path d="M6 5h10.5l-1.8 4 1.8 4H6"/></svg>`,
  login: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 5h4a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-4"/><path d="m10 8 4 4-4 4M14 12H4"/></svg>`,
  calendar: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 5.5h14v14H5z"/><path d="M8 3.5v4M16 3.5v4M5 9h14"/></svg>`,
  book: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4.5 5.5A3.5 3.5 0 0 1 8 2h11v17H8a3.5 3.5 0 0 0-3.5 3.5z"/><path d="M8 2v17"/></svg>`,
  devices: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3.5 5.5h12v8h-12z"/><path d="M8 17.5h3M6.5 17.5h6M17.5 9.5h3v8h-3z"/><path d="M18.25 15.5h1.5"/></svg>`,
  grad: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m3.5 8.5 8.5-4 8.5 4-8.5 4z"/><path d="M6.5 10.25v4.25c1.6 1.4 3.35 2.1 5.5 2.1s3.9-.7 5.5-2.1v-4.25"/></svg>`,
} as const;

const getStepIcon = (icon: string) => {
  if (icon === "bot") return iconMap.bot;
  if (icon === "code-xml") return iconMap.code;
  if (icon === "flag") return iconMap.flag;
  return iconMap.sparkles;
};

const getPricingIcon = (icon: string) => {
  if (icon === "calendar-days") return iconMap.calendar;
  if (icon === "book-open") return iconMap.book;
  return iconMap.login;
};

const getCourseIcon = (icon: string) => {
  if (icon === "bot") return iconMap.bot;
  if (icon === "code") return iconMap.code;
  if (icon === "devices") return iconMap.devices;
  if (icon === "grad") return iconMap.grad;
  return iconMap.book;
};

const stepImages = [jukuImage, robotImage, programmingImage, ctaImage];

const courseSections = [
  {
    id: "juku",
    tone: "blue",
    icon: "book",
    title: content.juku.title,
    body: content.juku.desc,
    image: jukuImage,
    imageAlt: content.juku.imgAlt,
    listTitle: content.juku.featuresLabel,
    items: content.juku.features,
  },
  {
    id: "robot-programming",
    tone: "lime",
    icon: "bot",
    title: content.robotProgramming.title,
    body: content.robotProgramming.desc,
    image: robotImage,
    imageAlt: content.robotProgramming.imgAlt,
    courses: content.robotProgramming.courses,
  },
  {
    id: "practical-programming",
    tone: "teal",
    icon: "code",
    title: content.practicalProgramming.title,
    body: content.practicalProgramming.desc,
    image: programmingImage,
    imageAlt: content.robotProgramming.progImgAlt,
    listTitle: content.practicalProgramming.contentsLabel,
    items: content.practicalProgramming.contents,
  },
  {
    id: "pc-smartphone",
    tone: "coral",
    icon: "devices",
    title: content.pcSmartphone.title,
    body: content.pcSmartphone.desc,
    image: pcImage,
    imageAlt: content.pcSmartphone.imgAlt,
    listTitle: content.pcSmartphone.levelsLabel,
    items: content.pcSmartphone.levels,
  },
  {
    id: "ged",
    tone: "red",
    icon: "grad",
    title: content.ged.title,
    body: content.ged.desc,
    image: gedImage,
    imageAlt: content.ged.title,
    listTitle: content.ged.supportLabel,
    items: content.ged.supports,
  },
];

const courseDisplayHighlights: Record<string, string[]> = {
  juku: ["定期テスト対策", "高校受験対策", "苦手科目の克服"],
  "robot-programming": [
    "ビジュアルプログラミング",
    "ロボット組立・制御",
    "コンテスト対策",
  ],
  "practical-programming": ["Web制作", "アプリ開発", "データ活用・AI基礎"],
  "pc-smartphone": ["基本操作", "トラブル解決", "スマホ活用"],
  ged: ["科目別対策", "過去問演習", "学習計画サポート"],
};

const getCourseHighlights = (section: (typeof courseSections)[number]) => {
  if (courseDisplayHighlights[section.id]) {
    return courseDisplayHighlights[section.id];
  }
  if ("items" in section && section.items) return section.items.slice(0, 3);
  if ("courses" in section && section.courses) {
    return section.courses.map((course) => course.title);
  }
  return [];
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "EducationalOrganization",
      name: "Acecore Schools",
      description: content.description,
      url: canonicalUrl,
      parentOrganization: {
        "@type": "Organization",
        name: "Acecore",
        url: acecoreOrigin,
      },
    },
    ...courseSections.map((section) => ({
      "@type": "Course",
      name: section.title,
      description: section.body,
      provider: { "@type": "EducationalOrganization", name: "Acecore Schools" },
      url: `${canonicalUrl}#${section.id}`,
    })),
  ],
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{content.title} | Acecore</title>
    <meta name="description" content={content.description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={`${content.title} | Acecore`} />
    <meta property="og:description" content={content.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta
      property="og:image"
      content={new URL(heroImage, schoolsOrigin).href}
    />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={canonicalPath} aria-label="Acecore Schools">
        <span class="brand-mark" aria-hidden="true"></span>
        <span class="brand-text">Acecore <small>Schools</small></span>
      </a>
      <nav class="primary-nav" aria-label="School sections">
        <a href="#juku">{content.juku.title}</a>
        <a href="#robot-programming">{content.robotProgramming.title}</a>
        <a href="#pricing">料金</a>
        <a href={acecoreOrigin} target="_blank" rel="noopener noreferrer"
          >Acecore.net</a
        >
      </nav>
      <a class="header-cta" href={contactUrl}>
        <span class="button-icon" set:html={iconMap.mail} />
        <span>{content.ctaForm}</span>
      </a>
    </header>

    <main>
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-media" aria-hidden="true">
          <img
            src={heroImage}
            alt=""
            width="1800"
            height="1013"
            loading="eager"
            fetchpriority="high"
          />
        </div>
        <div class="hero-content">
          <p class="hero-kicker">{heroKicker}</p>
          <h1 id="hero-title">{content.heroTitle}</h1>
          <p class="hero-lead">{content.heroSubtitle}</p>
          <div class="hero-actions">
            <a class="button primary" href={contactUrl}>
              <span class="button-icon" set:html={iconMap.mail} />
              <span>{content.ctaForm}</span>
            </a>
            <a
              class="button line"
              href={lineUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="button-icon" set:html={iconMap.chat} />
              <span>{content.ctaLine}</span>
            </a>
          </div>
        </div>
        <a class="scroll-cue" href="#learning-flow">
          <span aria-hidden="true">↓</span>
          <span>{scrollLabel}</span>
        </a>
      </section>

      <div class="language-strip" aria-label="Language display">
        <span class="language-globe" set:html={iconMap.globe} />
        <div class="language-list">
          {
            languageLabels.map((label) => (
              <span class:list={{ active: label === "日本語" }}>{label}</span>
            ))
          }
        </div>
      </div>

      <section
        class="flow-section"
        id="learning-flow"
        aria-labelledby="flow-title"
      >
        <div class="section-heading centered">
          <p>学びの流れ</p>
          <h2 id="flow-title">「わかる」から「できる」へ、4つのステップ</h2>
        </div>
        <div class="flow-grid">
          {
            content.learningSteps.map((step, index) => (
              <article class="flow-card">
                <figure>
                  <img
                    src={stepImages[index]}
                    alt=""
                    width="640"
                    height="420"
                    loading="lazy"
                  />
                </figure>
                <div class="step-heading">
                  <span class="step-number">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <span
                    class:list={["step-icon", `accent-${step.accent}`]}
                    set:html={getStepIcon(step.icon)}
                  />
                </div>
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="compare-section" aria-labelledby="compare-title">
        <div class="section-heading centered">
          <h2 id="compare-title" class="compare-title">
            <span>{content.compareBefore}</span>
            <small>vs</small>
            <span>{content.compareAfter}</span>
          </h2>
        </div>
        <div class="compare-grid">
          <div class="compare-column compare-before">
            <h3>{content.compareBefore}</h3>
            <ul>
              {
                content.compareBeforeItems.map((item) => (
                  <li>
                    <span aria-hidden="true">?</span>
                    <strong>{item}</strong>
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="compare-divider" aria-hidden="true">vs</div>
          <div class="compare-column compare-after">
            <h3>{content.compareAfter}</h3>
            <ul>
              {
                content.compareAfterItems.map((item) => (
                  <li>
                    <span aria-hidden="true">✓</span>
                    <strong>{item}</strong>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </section>

      <section class="courses" aria-labelledby="courses-title">
        <div class="section-heading centered">
          <h2 id="courses-title">目的に合わせて選べる、5つのコース</h2>
        </div>
        <div class="course-grid">
          {
            courseSections.map((section) => (
              <article
                class:list={["course-card", `tone-${section.tone}`]}
                id={section.id}
              >
                <img
                  src={section.image}
                  alt={section.imageAlt}
                  width="620"
                  height="420"
                  loading="lazy"
                />
                <div class="course-card-body">
                  <span
                    class="course-icon"
                    set:html={getCourseIcon(section.icon)}
                  />
                  <h3>{section.title}</h3>
                  <p>{section.body}</p>
                  <ul>
                    {getCourseHighlights(section).map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                  <a href={contactUrl}>
                    {detailLabel} <span aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="pricing" id="pricing" aria-labelledby="pricing-title">
        <div class="section-heading centered">
          <h2 id="pricing-title">料金のご案内</h2>
        </div>
        <div class="pricing-grid">
          {
            content.pricing.items.map((item, index) => (
              <article class:list={["pricing-card", `price-tone-${index + 1}`]}>
                <span
                  class="pricing-icon"
                  set:html={getPricingIcon(item.icon)}
                />
                <h3>{item.label}</h3>
                <p class="price">{item.price}</p>
                <p>{item.note}</p>
              </article>
            ))
          }
        </div>
        <p class="pricing-note">{content.pricing.ctaBody}</p>
      </section>

      <section class="final-cta" aria-labelledby="cta-title">
        <div class="final-media" aria-hidden="true">
          <img src={ctaImage} alt="" width="1800" height="900" loading="lazy" />
        </div>
        <div class="final-content">
          <h2 id="cta-title">{content.ctaHeading}</h2>
          <p>{content.ctaBody}</p>
          <div class="hero-actions">
            <a class="button primary" href={contactUrl}>
              <span class="button-icon" set:html={iconMap.mail} />
              <span>{content.ctaForm}</span>
            </a>
            <a
              class="button line"
              href={lineUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="button-icon" set:html={iconMap.chat} />
              <span>{content.ctaLine}</span>
            </a>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <a class="footer-brand" href={acecoreOrigin}>
        <span class="brand-mark" aria-hidden="true"></span>
        <span>Acecore Schools</span>
      </a>
      <nav aria-label="Footer navigation">
        <a href="#juku">{content.juku.title}</a>
        <a href="#robot-programming">{content.robotProgramming.title}</a>
        <a href="#pricing">{content.pricing.title}</a>
        <a href={acecoreOrigin}>Acecore.net</a>
        <a href={contactUrl}>{content.ctaForm}</a>
      </nav>
    </footer>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --page: #fbfcfc;
    --paper: #ffffff;
    --ink: #111717;
    --text: #263434;
    --muted: #667574;
    --line: rgba(17, 23, 23, 0.12);
    --line-strong: rgba(17, 23, 23, 0.18);
    --teal: #008f8a;
    --teal-deep: #006b69;
    --teal-soft: #dff5f2;
    --coral: #ff624f;
    --coral-deep: #e84635;
    --lime: #80bc18;
    --blue: #208cc8;
    --amber: #ffb23f;
    --footer: #0c2e33;
    --shadow: 0 18px 54px rgba(12, 46, 51, 0.14);
    font-family:
      Inter,
      "Noto Sans JP",
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    background: var(--page);
    color: var(--text);
    scroll-behavior: smooth;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    min-width: 320px;
    margin: 0;
    overflow-x: hidden;
    background: var(--page);
  }

  body {
    min-height: 100vh;
  }

  a {
    color: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  h1,
  h2,
  h3,
  p,
  figure {
    margin: 0;
  }

  .site-header {
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    z-index: 30;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    gap: 18px;
    align-items: center;
    min-height: 64px;
    padding: 14px max(22px, calc((100vw - 1320px) / 2));
    pointer-events: none;
  }

  .brand,
  .primary-nav,
  .hero-actions,
  footer,
  .footer-brand {
    display: flex;
    align-items: center;
  }

  .brand,
  .header-cta,
  .primary-nav {
    pointer-events: auto;
  }

  .brand {
    justify-self: start;
    min-width: 0;
    gap: 9px;
    color: var(--teal-deep);
    font-size: 1.32rem;
    font-weight: 900;
    line-height: 0.98;
    text-decoration: none;
  }

  .brand-text {
    display: grid;
  }

  .brand small {
    color: #657171;
    font-size: 0.84rem;
    font-weight: 760;
  }

  .brand-mark {
    position: relative;
    display: block;
    flex: 0 0 auto;
    width: 32px;
    height: 38px;
  }

  .brand-mark::before,
  .brand-mark::after {
    position: absolute;
    bottom: 0;
    width: 12px;
    border-radius: 2px 2px 0 0;
    content: "";
  }

  .brand-mark::before {
    left: 5px;
    height: 38px;
    background: var(--teal);
    transform: skew(-28deg);
  }

  .brand-mark::after {
    right: 5px;
    height: 26px;
    background: var(--coral);
    transform: skew(28deg);
  }

  .primary-nav {
    justify-self: center;
    gap: 1px;
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: 8px;
    padding: 3px;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 10px 30px rgba(12, 46, 51, 0.1);
    backdrop-filter: blur(18px);
  }

  .primary-nav a,
  .header-cta {
    border-radius: 6px;
    padding: 10px 18px;
    color: var(--ink);
    font-size: 0.88rem;
    font-weight: 860;
    line-height: 1.15;
    text-decoration: none;
    white-space: nowrap;
  }

  .primary-nav a:hover {
    background: var(--teal-soft);
    color: var(--teal-deep);
  }

  .header-cta {
    display: inline-flex;
    justify-self: end;
    align-items: center;
    justify-content: center;
    max-width: 100%;
    background: var(--coral);
    color: white;
    box-shadow: 0 12px 28px rgba(255, 98, 79, 0.24);
  }

  .hero {
    position: relative;
    display: grid;
    align-items: center;
    min-height: clamp(410px, 50vw, 660px);
    padding: clamp(96px, 9vw, 130px) max(22px, calc((100vw - 1320px) / 2))
      clamp(46px, 5.4vw, 82px);
    overflow: hidden;
    isolation: isolate;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: -2;
    background: #edf4f4;
  }

  .hero-media::after {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.99) 0%,
        rgba(255, 255, 255, 0.87) 32%,
        rgba(255, 255, 255, 0.22) 58%,
        rgba(255, 255, 255, 0.02) 100%
      ),
      linear-gradient(0deg, var(--page) 0%, rgba(251, 252, 252, 0) 10%);
    content: "";
  }

  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 63% 50%;
  }

  .hero-content {
    width: min(420px, 100%);
    min-width: 0;
    padding-top: 0;
  }

  .hero-kicker {
    display: inline-flex;
    max-width: 100%;
    border-radius: 8px;
    padding: 9px 16px;
    background: var(--teal);
    color: white;
    font-size: 0.82rem;
    font-weight: 900;
    line-height: 1.2;
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 430px;
    margin-top: 18px;
    color: var(--ink);
    font-size: clamp(4.45rem, 7.2vw, 5.9rem);
    font-weight: 950;
    line-height: 0.92;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .hero-lead {
    max-width: 390px;
    margin-top: 16px;
    color: var(--ink);
    font-size: clamp(1.35rem, 2.35vw, 1.72rem);
    font-weight: 900;
    line-height: 1.42;
    text-wrap: balance;
  }

  .hero-actions {
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 28px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    max-width: 100%;
    border: 1px solid transparent;
    border-radius: 8px;
    padding: 12px 20px;
    font-size: 0.86rem;
    font-weight: 900;
    line-height: 1.18;
    text-align: center;
    text-decoration: none;
    transition:
      transform 160ms ease,
