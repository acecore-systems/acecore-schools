---
import {
  acecoreOrigin,
  lineUrl,
  schoolsContent,
  schoolsOrigin,
} from "../data/schools";
import { schoolsDetailContent } from "../data/schools-details";

const content = schoolsContent;
const detail = schoolsDetailContent;
const canonicalPath = "/";
const canonicalUrl = new URL(canonicalPath, schoolsOrigin).href;
const contactUrl = acecoreOrigin + "/contact/";
const pricingUrl = "#pricing";
const trialInquiryUrl = lineUrl;
const trialUrl = "#trial";

const mangaImages = {
  study: "/images/schools/manga-study.png",
  robot: "/images/schools/manga-robot.png",
  programming: "/images/schools/manga-programming.png",
  pc: "/images/schools/manga-pc-smartphone.png",
  ged: "/images/schools/manga-ged.png",
  consultation: "/images/schools/manga-consultation.png",
  agHeroBoard: "/images/schools/ag-hero-board.png",
  agTrial: "/images/schools/ag-trial-figure.png",
  agCourseTutoring: "/images/schools/ag-course-tutoring.png",
  agCourseRobot: "/images/schools/ag-course-robot.png",
  agCourseProgramming: "/images/schools/ag-course-programming.png",
  agCoursePc: "/images/schools/ag-course-pc-smartphone.png",
  agCourseGed: "/images/schools/ag-course-ged.png",
  agFinalStrip: "/images/schools/ag-final-strip.png",
} as const;

const navItems = [
  { href: trialUrl, label: "無料体験" },
  { href: "#courses", label: "コース" },
  { href: "#schedule", label: "時間帯" },
  { href: pricingUrl, label: "料金" },
  { href: "#faq", label: "FAQ" },
];

const heroPanels = [
  {
    area: "panel-programming",
    image: mangaImages.programming,
    alt: "コードエディタと設計ノートの漫画調イラスト",
    label: "実践プログラミング",
    caption: "コードを書いて、\n仕組みをつくる。",
  },
  {
    area: "panel-robot",
    image: mangaImages.robot,
    alt: "ロボット工作キットとセンサー部品の漫画調イラスト",
    label: "ロボット工作・制御",
    caption: "組み立てて、\n動かして、考える。",
  },
  {
    area: "panel-pc",
    image: mangaImages.pc,
    alt: "スマートフォンとパソコン操作の漫画調イラスト",
    label: "パソコン/スマホ",
    caption: "基本操作から活用まで。",
  },
  {
    area: "panel-ged",
    image: mangaImages.ged,
    alt: "高卒認定の学習教材と計画表の漫画調イラスト",
    label: "高卒認定",
    caption: "未来の選択肢を、\nしっかり広げる。",
  },
  {
    area: "panel-consultation",
    image: mangaImages.consultation,
    alt: "相談シートと学習計画を作る漫画調イラスト",
    label: "まずは相談から。",
    caption: "毎週の学びの快適さを\n一緒に描きます。",
  },
];

const courseSections = [
  {
    id: "juku",
    number: "01",
    tone: "#0f4d8b",
    title: content.juku.title,
    body: "基礎学力から応用まで、一人ひとりに合わせた学習をサポート。",
    image: mangaImages.agCourseTutoring,
    imageAlt: "学習ノートと教材",
    items: content.juku.features.slice(0, 2),
  },
  {
    id: "robot-control",
    number: "02",
    tone: "#e06e00",
    title: content.robotProgramming.title,
    body: "センサーやモーターを使い、組み立てて動かす制御の仕組みを学ぶ。",
    image: mangaImages.agCourseRobot,
    imageAlt: "ロボット工作キット",
    items: content.robotProgramming.courses.map((course) => course.title),
  },
  {
    id: "practical-programming",
    number: "03",
    tone: "#0f4d8b",
    title: content.practicalProgramming.title,
    body: "Web・アプリ開発、Git、API、データベース、クラウドまで実践的に学ぶ。",
    image: mangaImages.agCourseProgramming,
    imageAlt: "コードエディタと設計ノート",
    items: content.practicalProgramming.contents.slice(0, 3),
  },
  {
    id: "pc-smartphone",
    number: "04",
    tone: "#d9473d",
    title: content.pcSmartphone.title,
    body: "基本操作から仕事や日常で役立つ活用まで、やさしく丁寧にサポート。",
    image: mangaImages.agCoursePc,
    imageAlt: "スマートフォンとパソコン",
    items: content.pcSmartphone.levels.slice(0, 3),
  },
  {
    id: "ged",
    number: "05",
    tone: "#6b3aa0",
    title: content.ged.title,
    body: "高卒認定試験の学習を個別に合わせて、しっかりサポート。",
    image: mangaImages.agCourseGed,
    imageAlt: "高卒認定の教材",
    items: content.ged.supports.slice(0, 3),
  },
];

const learningSteps = [
  {
    number: "1",
    title: "発見",
    icon: "search",
    body: "興味を見つける。やりたいことを明確にする。",
  },
  {
    number: "2",
    title: "理解",
    icon: "book",
    body: "体験して理解する。小さな成功体験で自信をつくる。",
  },
  {
    number: "3",
    title: "応用",
    icon: "code",
    body: "できることが増える。スキルを組み上げて応用の幅を広げる。",
  },
  {
    number: "4",
    title: "定着",
    icon: "target",
    body: "生活で活かす。学んだことを日常や将来に活かす。",
  },
] as const;

const compareBeforeItems = [
  "何から始めればいいかわからない",
  "モチベーションの維持が難しい",
  "つまずきの解決に時間がかかる",
  "学習の効果を実感しにくい",
];

const compareAfterItems = [
  "個別サポートで最短ルート",
  "小さな成功で継続しやすい",
  "講師がすぐにサポート",
  "「できた！」を積み重ねる",
];

const scheduleSlots = [
  { time: "10:00-12:00", cells: ["○", "○", "○", "○", "○", "△", "−"] },
  { time: "15:00-17:00", cells: ["○", "○", "○", "○", "○", "△", "−"] },
  { time: "17:00-19:00", cells: ["○", "○", "○", "○", "○", "△", "−"] },
  { time: "19:00-21:00", cells: ["○", "○", "○", "○", "○", "△", "−"] },
  { time: "21:00-22:00", cells: ["○", "○", "○", "○", "○", "△", "休"] },
];

const faqPreviewItems = [
  {
    question: "無料体験では何をしますか？",
    answer:
      "学習状況、目標、困っていることを確認し、短い体験授業と今後の進め方を提案します。",
  },
  {
    question: "どのコースを選べばいいかわかりません。",
    answer:
      "無料体験で目的と現在地を整理し、学習塾、ロボット、プログラミングなどから合う入口を提案します。",
  },
  {
    question: "途中でコースの変更はできますか？",
    answer:
      "可能です。目標や進み具合に合わせて、学習内容や頻度を相談しながら調整します。",
  },
  {
    question: "支払い方法は何がありますか？",
    answer:
      "詳細は無料体験時にご案内します。月謝や教材費の目安もあわせて確認できます。",
  },
  {
    question: "パソコンや教材は用意する必要がありますか？",
    answer:
      "内容により異なります。必要な持ち物や代替方法は予約後に案内します。",
  },
];

const iconMap = {
  search: `<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="10.5" cy="10.5" r="6.5"/><path d="m15.5 15.5 4 4"/></svg>`,
  book: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5.5c2.7 0 5.2.45 8 2.4 2.8-1.95 5.3-2.4 8-2.4v13c-2.7 0-5.2.45-8 2.4-2.8-1.95-5.3-2.4-8-2.4z"/><path d="M12 7.9v13"/></svg>`,
  code: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 8-4 4 4 4M15 8l4 4-4 4"/></svg>`,
  target: `<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="4"/><path d="M12 2v4M12 18v4M2 12h4M18 12h4"/></svg>`,
  calendar: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 5.5h14v14H5z"/><path d="M8 3.5v4M16 3.5v4M5 10h14"/></svg>`,
  wallet: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4.5 7.5h15v11h-15z"/><path d="M6.5 7.5V5.8l10-1.7v3.4"/><path d="M15.5 13h4"/></svg>`,
  bookOpen: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5.5h6.5A3.5 3.5 0 0 1 14 9v10a3.5 3.5 0 0 0-3.5-3.5H4z"/><path d="M20 5.5h-6.5A3.5 3.5 0 0 0 10 9v10a3.5 3.5 0 0 1 3.5-3.5H20z"/></svg>`,
};

const getPricingIcon = (icon: string) => {
  if (icon === "calendar-days") return iconMap.calendar;
  if (icon === "book-open") return iconMap.bookOpen;
  return iconMap.wallet;
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "EducationalOrganization",
      name: "Acecore Schools",
      description: content.description,
      url: canonicalUrl,
      parentOrganization: {
        "@type": "Organization",
        name: "Acecore",
        url: acecoreOrigin,
      },
    },
    ...courseSections.map((section) => ({
      "@type": "Course",
      name: section.title,
      description: section.body,
      provider: { "@type": "EducationalOrganization", name: "Acecore Schools" },
      url: `${canonicalUrl}#${section.id}`,
    })),
    {
      "@type": "FAQPage",
      mainEntity: detail.faqs.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ],
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{content.title} | Acecore</title>
    <meta name="description" content={content.description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={`${content.title} | Acecore`} />
    <meta property="og:description" content={content.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta
      property="og:image"
      content={new URL(mangaImages.consultation, schoolsOrigin).href}
    />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={canonicalPath} aria-label="Acecore Schools">
        <span>Acecore Schools</span>
      </a>
      <nav class="primary-nav" aria-label="School sections">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
      <a
        class="header-cta"
        href={trialInquiryUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="line-badge" aria-hidden="true">LINE</span>
        <span>LINEで無料体験を相談する</span>
        <span aria-hidden="true">›</span>
      </a>
    </header>

    <main class="comic-page">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy panel panel-hero-copy">
          <div class="speed-lines" aria-hidden="true"></div>
          <h1 id="hero-title">{content.heroTitle}</h1>
          <p class="hero-lead">
            <span>一人ひとりに合わせたサポートで、</span>
            <span>ITを「わかる」から「できる」へ。</span>
          </p>
          <p class="hero-body">
            <span>あなたのペースに合わせた学びの設計。</span>
            <span>一緒に選び、進め、未来につなげます。</span>
          </p>
          <div class="hero-actions">
            <a
              class="button button-line"
              href={trialInquiryUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="line-badge" aria-hidden="true">LINE</span>
              <span>{detail.trial.primaryCta}</span>
            </a>
            <a class="button button-plain" href={pricingUrl}>
              <span>{detail.trial.secondaryCta}</span>
              <span aria-hidden="true">›</span>
            </a>
          </div>
        </div>

        <div class="hero-board" aria-label="Acecore Schoolsの学びのコマ">
          {
            heroPanels.map((heroPanel) => (
              <article class:list={["manga-panel", heroPanel.area]}>
                <img
                  src={heroPanel.image}
                  alt={heroPanel.alt}
                  width="1536"
                  height="1024"
                  loading="eager"
                  fetchpriority="high"
                />
                <div class="panel-caption">
                  <strong>{heroPanel.label}</strong>
                  <span>{heroPanel.caption}</span>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="sheet-grid" aria-label="Acecore Schools details">
        <div class="sheet-row sheet-row-primary">
          <section
            class="panel trial-panel"
            id="trial"
            aria-labelledby="trial-title"
          >
          <header class="panel-heading">
            <span class="panel-number">01</span>
            <h2 id="trial-title">無料体験</h2>
          </header>
          <p>まずは相談から。学びの地図を一緒に描きます。</p>
          <ul class="check-list">
            <li>ヒアリング</li>
            <li>体験レッスン</li>
            <li>学習プラン提案</li>
          </ul>
          <figure class="panel-figure">
            <img
              src={mangaImages.agTrial}
              alt="無料体験の相談シート"
              width="1536"
              height="1024"
              loading="lazy"
            />
          </figure>
          <p class="small-note">所要時間: 約60分</p>
          </section>

          <section class="panel flow-panel" aria-labelledby="flow-title">
          <header class="panel-heading">
            <span class="panel-number">02</span>
            <h2 id="flow-title">学びの流れ</h2>
            <small>4つのステップ</small>
          </header>
          <div class="flow-list">
            {
              learningSteps.map((step) => (
                <article class="flow-step">
                  <span class="step-number">{step.number}</span>
                  <span class="step-icon" set:html={iconMap[step.icon]} />
                  <h3>{step.title}</h3>
                  <p>{step.body}</p>
                </article>
              ))
            }
          </div>
          </section>

          <section
            class="panel courses-panel"
            id="courses"
            aria-labelledby="courses-title"
          >
          <header class="panel-heading">
            <span class="panel-number">03</span>
            <h2 id="courses-title">コース一覧</h2>
            <small>目的に合わせて選べる5つのコース</small>
          </header>
          <div class="course-grid">
            {
              courseSections.map((section) => (
                <article
                  class="course-card"
                  id={section.id}
                  style={`--course-tone: ${section.tone}`}
                >
                  <h3 class="course-title">{section.title}</h3>
                  <figure>
                    <img
                      src={section.image}
                      alt={section.imageAlt}
                      width="1536"
                      height="1024"
                      loading="lazy"
                    />
                  </figure>
                  <p>{section.body}</p>
                </article>
              ))
            }
          </div>
          </section>
        </div>

        <div class="sheet-row sheet-row-secondary">
          <section class="panel compare-panel" aria-labelledby="compare-title">
          <header class="panel-heading">
            <span class="panel-number">04</span>
            <h2 id="compare-title">独学とAcecore Schoolsの比較</h2>
          </header>
          <div class="compare-grid">
            <div>
              <h3>{content.compareBefore}</h3>
              <ul>
                {
                  compareBeforeItems.map((item) => (
                    <li>
                      <span aria-hidden="true">×</span>
                      <strong>{item}</strong>
                    </li>
                  ))
                }
              </ul>
            </div>
            <span class="versus" aria-hidden="true">VS</span>
            <div>
              <h3>{content.compareAfter}</h3>
              <ul>
                {
                  compareAfterItems.map((item) => (
                    <li>
                      <span aria-hidden="true">✓</span>
                      <strong>{item}</strong>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
          </section>

          <section
            class="panel schedule-panel"
            id="schedule"
            aria-labelledby="schedule-title"
          >
          <header class="panel-heading">
            <span class="panel-number">05</span>
            <h2 id="schedule-title">時間帯</h2>
            <small>開校時間・利用可能時間</small>
          </header>
            <div class="table-wrap schedule-wrap">
              <table class="schedule-matrix" aria-label="時間帯の空き状況">
                <thead>
                  <tr>
                    <th>時間帯</th>
                    <th>月</th>
                    <th>火</th>
                    <th>水</th>
                    <th>木</th>
                    <th>金</th>
                    <th>土</th>
                    <th class="holiday">日</th>
                  </tr>
                </thead>
                <tbody>
                  {
                    scheduleSlots.map((slot) => (
                      <tr>
                        <td>{slot.time}</td>
                        {slot.cells.map((cell) => (
                          <td class:list={[cell === "休" && "holiday"]}>
                            {cell}
                          </td>
                        ))}
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>
            <p class="schedule-legend">
              ○ 利用可能　△ 応相談　− 非開校　<span>休</span> 定休日
            </p>
            <p class="small-note">上記時間内でご都合に合わせて予約いただけます。</p>
          </section>

          <section
            class="panel pricing-panel"
            id="pricing"
            aria-labelledby="pricing-title"
          >
            <header class="panel-heading">
              <span class="panel-number">06</span>
              <h2 id="pricing-title">料金の目安</h2>
              <small>ガイド</small>
            </header>
            <div class="price-list">
              {
                content.pricing.items.map((item) => (
                  <article>
                    <span
                      class="price-icon"
                      set:html={getPricingIcon(item.icon)}
                    />
                    <h3>{item.label}</h3>
                    <strong>{item.price}</strong>
                  </article>
                ))
              }
            </div>
            <p class="small-note">
              ※ 料金は目安です。詳細は無料体験時にご案内します。
            </p>
          </section>

          <section class="panel faq-panel" id="faq" aria-labelledby="faq-title">
            <header class="panel-heading">
              <span class="panel-number">07</span>
              <h2 id="faq-title">FAQ</h2>
              <small>よくあるご質問</small>
            </header>
            <div class="faq-list">
              {
                faqPreviewItems.map((item) => (
                  <details>
                    <summary>{item.question}</summary>
                    <p>{item.answer}</p>
                  </details>
                ))
              }
            </div>
          </section>
        </div>

        <section class="final-panel" aria-labelledby="final-title">
          <div class="final-copy">
            <span class="panel-number">08</span>
            <h2 id="final-title">次の一歩を、ここから。</h2>
            <p>
              あなた専用の学びのプランで、「できる！」を増やしていきましょう。
            </p>
          </div>
          <div class="final-strip-images" aria-hidden="true">
            <img
              src={mangaImages.robot}
              alt=""
              width="1536"
              height="1024"
              loading="lazy"
            />
            <img
              src={mangaImages.consultation}
              alt=""
              width="1536"
              height="1024"
              loading="lazy"
            />
            <img
              src={mangaImages.programming}
              alt=""
              width="1536"
              height="1024"
              loading="lazy"
            />
            <img
              src={mangaImages.study}
              alt=""
              width="1536"
              height="1024"
              loading="lazy"
            />
          </div>
          <div class="final-cta">
            <a
              class="final-cta-primary"
              href={trialInquiryUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="line-badge" aria-hidden="true">LINE</span>
              <span>{detail.finalCta.primary}</span>
              <span aria-hidden="true">›</span>
            </a>
            <a class="final-cta-secondary" href={pricingUrl}>
              <span>{detail.finalCta.secondary}</span>
              <span aria-hidden="true">›</span>
            </a>
          </div>
        </section>
      </section>
    </main>

    <footer class="site-footer">
      <a href={acecoreOrigin}>Acecore</a>
      <nav aria-label="Footer navigation">
        <a href={contactUrl}>{content.ctaForm}</a>
        <a href={pricingUrl}>{detail.trial.secondaryCta}</a>
        <a href={trialInquiryUrl}>LINE</a>
      </nav>
    </footer>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --paper: #ffffff;
    --ink: #080b0d;
    --navy: #073b78;
    --green: #009f3a;
    --green-dark: #007d2e;
    --red: #d94135;
    --muted: #4f5961;
    --line: #0a0d0f;
    --panel-gap: 5px;
    font-family:
      "Arial",
      "Noto Sans JP",
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    background: var(--paper);
    color: var(--ink);
    scroll-behavior: smooth;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    min-width: 320px;
    margin: 0;
    background: var(--paper);
  }

  body {
    overflow-x: hidden;
  }

  a {
    color: inherit;
  }

  img,
  svg {
    display: block;
  }

  img {
    max-width: 100%;
  }

  h1,
  h2,
  h3,
  p,
  figure {
    margin: 0;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 28px;
    align-items: center;
    min-height: 60px;
    border-top: 2px solid var(--line);
    border-bottom: 2px solid var(--line);
    padding: 0 24px;
    width: min(1536px, 100vw);
    margin: 0 auto;
    background: #fff;
  }

  .brand,
  .site-footer a {
    text-decoration: none;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    color: var(--ink);
    font-size: 1.7rem;
    font-weight: 950;
    line-height: 1;
  }

  .brand-mark {
    position: relative;
    width: 30px;
    height: 30px;
    border: 3px solid var(--ink);
    transform: rotate(30deg);
  }

  .brand-mark::before,
  .brand-mark::after {
    position: absolute;
    inset: 5px;
    border: 2px solid var(--ink);
    content: "";
  }

  .brand-mark::after {
    inset: auto;
    top: -3px;
    bottom: -3px;
    left: 50%;
    width: 2px;
    border: 0;
    background: var(--ink);
    transform: translateX(-50%);
  }

  .primary-nav {
    display: flex;
    gap: clamp(30px, 3.3vw, 50px);
    align-items: center;
    justify-content: flex-end;
  }

  .primary-nav a {
    font-size: 1.06rem;
    font-weight: 950;
    text-decoration: none;
    white-space: nowrap;
  }

  .header-cta,
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    max-width: 100%;
    min-height: 46px;
    border: 2px solid var(--line);
    border-radius: 5px;
    padding: 11px 18px;
    font-size: 0.95rem;
    font-weight: 950;
    line-height: 1.15;
    text-decoration: none;
  }

  .header-cta {
    justify-self: end;
    gap: 8px;
    width: 260px;
    min-height: 40px;
    border-color: var(--green-dark);
    padding: 5px 14px;
    background: var(--green);
    color: white;
    font-size: 0.9rem;
    box-shadow: inset 0 -2px 0 rgba(0, 0, 0, 0.16);
    white-space: nowrap;
  }

  .header-cta .line-badge {
    min-width: 34px;
    height: 24px;
    font-size: 0.66rem;
  }

  .line-badge {
    display: inline-grid;
    flex: 0 0 auto;
    place-items: center;
    min-width: 38px;
    height: 26px;
    border-radius: 999px;
    background: white;
    color: var(--green);
    font-size: 0.7rem;
    font-weight: 950;
    line-height: 1;
  }

  .comic-page {
    width: min(1536px, 100vw);
    border-right: 2px solid var(--line);
    border-bottom: 2px solid var(--line);
    border-left: 2px solid var(--line);
    margin: 0 auto;
    padding: 0 8px 8px;
    background: #fff;
  }

  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 480fr) minmax(0, 1046fr);
    gap: var(--panel-gap);
    height: 389px;
    background: #fff;
  }

  .hero::after {
    position: absolute;
    right: 0;
    bottom: -1px;
    left: 0;
    z-index: 4;
    height: 1px;
    background: var(--line);
    content: "";
    pointer-events: none;
  }

  .panel,
  .manga-panel {
    position: relative;
    overflow: hidden;
    border: 2px solid var(--line);
    background: #fff;
  }

  .panel-hero-copy {
    z-index: 2;
    min-height: 0;
    border-bottom: 0;
    overflow: visible;
    padding: 14px 32px 28px 23px;
    clip-path: none;
    isolation: isolate;
  }

  .panel-hero-copy::after {
    position: absolute;
    top: 0;
    right: -45px;
    z-index: 0;
    width: 45px;
    height: 100%;
    background: #fff;
    clip-path: polygon(0 0, 100% 0, 5% 100%, 0 100%);
    content: "";
  }

  .panel-hero-copy::before {
    position: absolute;
    top: 0;
    right: -52px;
    z-index: 1;
    width: 52px;
    height: 100%;
    background: var(--line);
    clip-path: polygon(82% 0, 100% 0, 19% 100%, 2% 100%);
    content: "";
  }

  .panel-hero-copy > :not(.speed-lines) {
    position: relative;
    z-index: 2;
  }

  .speed-lines {
    position: absolute;
    inset: 0 -45px 0 0;
    z-index: -1;
    opacity: 0.62;
    clip-path: polygon(0 0, 100% 0, calc(100% - 43px) 100%, 0 100%);
    background:
      repeating-conic-gradient(
        from 228deg at 97% 48%,
        transparent 0deg,
        transparent 5deg,
        rgba(8, 11, 13, 0.22) 5.4deg,
        transparent 6deg
      ),
      radial-gradient(circle at 18% 50%, #fff 0 46%, transparent 66%);
  }

  h1 {
    max-width: 7.5ch;
    color: #050709;
    font-size: clamp(4rem, 5.8vw, 5.75rem);
    font-weight: 950;
    line-height: 0.84;
    letter-spacing: 0;
    transform: scaleX(0.94);
    transform-origin: left top;
  }

  .panel-hero-copy > .hero-lead {
    max-width: none;
    margin-top: 15px;
    color: #111;
    font-size: 1.28rem;
    font-weight: 950;
    line-height: 1.25;
  }

  .panel-hero-copy > .hero-body {
    max-width: none;
    margin-top: 13px;
    color: #111;
    font-size: 0.9rem;
    font-weight: 760;
    line-height: 1.55;
  }

  .panel-hero-copy > .hero-lead span,
  .panel-hero-copy > .hero-body span {
    display: block;
  }

  .panel-hero-copy > .hero-actions {
    display: flex;
    flex-wrap: nowrap;
    gap: 10px;
    margin-top: 20px;
  }

  .panel-hero-copy > .hero-actions .button {
    min-height: 53px;
    padding: 10px 12px;
    font-size: 0.88rem;
    white-space: nowrap;
  }

  .panel-hero-copy > .hero-actions .line-badge {
    min-width: 35px;
    height: 24px;
    font-size: 0.66rem;
  }

  .panel-hero-copy > .hero-actions .button-line {
    flex: 0 0 260px;
  }

  .panel-hero-copy > .hero-actions .button-plain {
    flex: 0 0 164px;
  }

  .button-line,
  .final-cta-primary {
    gap: 9px;
    border-color: var(--green-dark);
    background: var(--green);
    color: white;
  }

  .button-plain {
    gap: 10px;
    background: #fff;
    color: #111;
  }

  .hero-board {
    position: relative;
    display: block;
    min-height: 0;
    background: var(--line);
  }

  @media (min-width: 761px) {
    .hero-board {
      background: url("/images/schools/ag-hero-board.png") center / 100% 100% no-repeat;
    }

    .hero-board .manga-panel {
      display: none;
    }
  }

  .manga-panel {
    position: absolute;
    min-height: 0;
  }

  .manga-panel::after,
  .panel-figure::after,
  .course-card figure::after,
  .final-strip-images::after {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      radial-gradient(rgba(0, 0, 0, 0.16) 0.7px, transparent 0.7px),
      linear-gradient(135deg, rgba(255, 255, 255, 0.08), transparent);
    background-size:
      5px 5px,
      100% 100%;
    mix-blend-mode: multiply;
    content: "";
  }

  .manga-panel img,
  .panel-figure img,
  .course-card img,
  .final-strip-images img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: contrast(1.03) saturate(0.94);
  }

  .trial-panel .panel-figure img,
  .course-card img[src*="ag-course"] {
    filter: none;
  }

  .final-strip-images img:nth-child(1) {
    clip-path: polygon(0 0, 96% 0, 100% 100%, 5% 100%);
  }

  .final-strip-images img:nth-child(2),
  .final-strip-images img:nth-child(3) {
    clip-path: polygon(2% 0, 96% 0, 100% 100%, 0 100%);
  }

  .final-strip-images img:nth-child(4) {
    clip-path: polygon(2% 0, 100% 0, 100% 100%, 0 100%);
  }

  .panel-programming {
    top: 0;
    left: 0;
    width: 41.4%;
    height: 226px;
    clip-path: polygon(8% 0, 100% 0, 99% 100%, 0 100%);
  }

  .panel-robot {
    top: 0;
    left: calc(41.4% + var(--panel-gap));
    width: 37.8%;
    height: 255px;
    clip-path: polygon(1% 0, 100% 0, 96% 100%, 0 100%);
  }

  .panel-pc {
    top: 0;
    right: 0;
    width: 19.8%;
    height: 255px;
    clip-path: polygon(3% 0, 100% 0, 100% 100%, 0 100%);
  }

  .panel-pc img {
    object-position: 18% 50%;
  }

  .panel-ged {
    bottom: 0;
    left: 0;
    width: 41.4%;
    height: 156px;
    clip-path: polygon(0 0, 99% 0, 100% 100%, 0 100%);
  }

  .panel-consultation {
    right: 0;
    bottom: 0;
    width: 58.4%;
    height: 126px;
    clip-path: polygon(1% 0, 100% 0, 100% 100%, 0 100%);
  }

  .panel-caption {
    position: absolute;
    right: 16px;
    bottom: 14px;
    max-width: min(310px, calc(100% - 32px));
    border: 2px solid var(--line);
    padding: 8px 11px;
    background: rgba(255, 255, 255, 0.94);
    color: #111;
  }

  .panel-caption strong,
  .panel-caption span {
    display: block;
  }

  .panel-caption strong {
    color: var(--navy);
    font-size: 0.78rem;
    font-weight: 950;
  }

  .panel-caption span {
    margin-top: 3px;
    font-size: 0.88rem;
    font-weight: 950;
    line-height: 1.35;
  }

  .hero-board .panel-caption strong {
    display: none;
  }

  .hero-board .panel-caption {
    padding: 7px 10px;
  }

  .hero-board .panel-caption span {
    margin-top: 0;
    font-size: 0.86rem;
    line-height: 1.25;
    white-space: pre-line;
  }

  .panel-programming .panel-caption {
    right: auto;
    bottom: 14px;
    left: 36px;
    max-width: 158px;
  }

  .panel-robot .panel-caption {
    right: auto;
    bottom: 32px;
    left: 28px;
    max-width: 190px;
  }

  .panel-pc .panel-caption {
    display: none;
  }

  .panel-ged .panel-caption {
    right: auto;
    bottom: 14px;
    left: 10px;
    max-width: 174px;
  }

  .panel-consultation .panel-caption {
    right: 80px;
    bottom: 14px;
    max-width: 178px;
  }

  .panel-consultation .panel-caption strong {
    display: block;
    color: #111;
    font-size: 0.82rem;
    line-height: 1.22;
  }

  .panel-consultation .panel-caption span {
    margin-top: 0;
    font-size: 0.82rem;
    line-height: 1.22;
  }

  .sheet-grid {
    display: grid;
    gap: 8px;
    margin-top: 9px;
    background: #fff;
  }

  .sheet-row {
    position: relative;
    display: grid;
    gap: var(--panel-gap);
    min-width: 0;
  }

  .sheet-row::after {
    position: absolute;
    right: 0;
    bottom: -1px;
    left: 0;
    z-index: 4;
    height: 1px;
    background: var(--line);
    content: "";
    pointer-events: none;
  }

  .sheet-row-primary {
    grid-template-columns: minmax(0, 326px) minmax(0, 480px) minmax(0, 1fr);
    gap: 10px;
    height: 227px;
  }

  .sheet-row-secondary {
    grid-template-columns:
      minmax(0, 486fr) minmax(0, 373fr) minmax(0, 289fr)
      minmax(0, 372fr);
    height: 204px;
  }

  .sheet-row > .panel,
  .final-panel {
    min-width: 0;
    min-height: 0;
    overflow: hidden;
    padding: 14px 16px;
    background: #fff;
  }

  .sheet-row-primary > .panel {
    border-bottom: 0;
    padding: 10px 16px;
  }

  .sheet-row-secondary > .panel {
    border-bottom: 0;
    padding: 8px 16px 8px;
  }

  .trial-panel {
    display: grid;
    grid-template-columns: 105px minmax(0, 1fr);
    column-gap: 6px;
    align-content: start;
  }

  .trial-panel .panel-heading {
    grid-column: 1 / -1;
  }

  .trial-panel > p {
    font-size: 0.68rem;
    line-height: 1.35;
  }

  .trial-panel > p,
  .trial-panel .check-list,
  .trial-panel .small-note {
    grid-column: 1;
  }

  .trial-panel .check-list {
    gap: 3px;
  }

  .trial-panel .check-list li {
    padding-left: 21px;
    font-size: 0.72rem;
    line-height: 1.35;
  }

  .trial-panel .panel-figure {
    grid-column: 2;
    grid-row: 2 / 5;
    align-self: start;
    height: 176px;
    border: 0;
    margin-top: -10px;
  }

  .trial-panel .panel-figure::after {
    display: none;
  }

  .final-panel {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 380fr) minmax(0, 565fr) minmax(0, 580fr);
    gap: var(--panel-gap);
    height: 109px;
    align-items: stretch;
    overflow: visible;
    padding: 0;
  }

  .final-panel::before,
  .final-panel::after {
    position: absolute;
    right: 0;
    left: 0;
    z-index: 5;
    height: 1px;
    background: var(--line);
    content: "";
    pointer-events: none;
  }

  .final-panel::before {
    top: -1px;
  }

  .final-panel::after {
    bottom: -1px;
  }

  .panel-heading {
    display: flex;
    gap: 9px;
    align-items: baseline;
    min-width: 0;
    margin-bottom: 7px;
  }

  .panel-number {
    color: var(--navy);
    font-size: clamp(1.65rem, 2.22vw, 2.18rem);
    font-weight: 950;
    line-height: 0.9;
  }

  .panel-heading h2,
  .final-copy h2 {
    color: #111;
    font-size: clamp(1.02rem, 1.28vw, 1.24rem);
    font-weight: 950;
    line-height: 1.2;
  }

  .panel-heading small {
    color: #333;
    font-size: 0.72rem;
    font-weight: 900;
  }

  .panel > p,
  .final-copy p,
  .small-note,
  .course-card p,
  .faq-list p {
    color: #111;
    font-size: 0.76rem;
    font-weight: 680;
    line-height: 1.45;
  }

  .check-list,
  .compare-grid ul {
    margin: 8px 0 0;
    padding: 0;
    list-style: none;
  }

  .check-list {
    display: grid;
    gap: 5px;
  }

  .check-list li {
    position: relative;
    padding-left: 24px;
    color: #111;
    font-size: 0.76rem;
    font-weight: 850;
    line-height: 1.5;
  }

  .check-list li::before {
    position: absolute;
    top: 0.28em;
    left: 0;
    width: 12px;
    height: 12px;
    border: 1.5px solid var(--red);
    background: #fff;
    content: "";
  }

  .check-list li::after {
    position: absolute;
    top: 0.01em;
    left: 2px;
    color: var(--red);
    font-size: 1rem;
    font-weight: 950;
    line-height: 1;
    content: "✓";
  }

  .panel-figure {
    position: relative;
    height: 118px;
    border: 2px solid var(--line);
    margin-top: 10px;
    overflow: hidden;
  }

  .small-note {
    margin-top: 8px;
    font-size: 0.72rem;
  }

  .schedule-panel {
    padding: 8px 14px 8px;
  }

  .schedule-panel .panel-heading {
    margin-bottom: 5px;
  }

  .schedule-panel .small-note,
  .pricing-panel .small-note {
    margin-top: 3px;
    font-size: 0.56rem;
    line-height: 1.14;
  }

  .flow-list {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 8px;
  }

  .flow-step {
    position: relative;
    min-width: 0;
    border-right: 1px solid #b9bec2;
    padding-right: 8px;
  }

  .flow-step:last-child {
    border-right: 0;
  }

  .flow-step + .flow-step::before {
    position: absolute;
    top: 35px;
    left: -10px;
    color: var(--navy);
    font-size: 1.55rem;
    font-weight: 950;
    content: "›";
  }

  .step-number {
    display: inline-grid;
    place-items: center;
    width: 24px;
    height: 24px;
    border-radius: 5px;
    background: var(--navy);
    color: white;
    font-size: 0.82rem;
    font-weight: 950;
  }

  .step-icon {
    display: grid;
    width: 35px;
    height: 35px;
    place-items: center;
    margin-top: 8px;
    color: #111;
  }

  .step-icon :global(svg),
  .price-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .step-icon :global(path),
  .step-icon :global(circle),
  .price-icon :global(path) {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.95;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .flow-step h3 {
    margin-top: 6px;
    color: #111;
    font-size: 0.86rem;
    font-weight: 950;
  }

  .flow-step p {
    margin-top: 4px;
    color: #111;
    font-size: 0.62rem;
    font-weight: 680;
    line-height: 1.34;
  }

  .course-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 7px;
  }

  .course-card {
    min-width: 0;
    border: 2px solid var(--line);
    background: white;
  }

  .course-title {
    display: grid;
    min-height: 28px;
    place-items: center;
    padding: 4px 5px;
    border-bottom: 2px solid var(--line);
    color: #111;
    font-size: 0.76rem;
    font-weight: 950;
    line-height: 1.12;
    text-align: center;
  }

  .course-card figure {
    position: relative;
    height: 78px;
    aspect-ratio: auto;
    overflow: hidden;
    border-bottom: 2px solid var(--line);
    background: #eee;
  }

  .course-card p {
    padding: 5px 7px;
    font-size: 0.59rem;
    line-height: 1.26;
  }

  .compare-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    gap: 8px;
    align-items: stretch;
  }

  .compare-grid > div {
    border: 2px solid var(--line);
    background: #fff;
  }

  .compare-grid h3 {
    border-bottom: 2px solid var(--line);
    padding: 5px 7px;
    background: #f3f5f7;
    color: #111;
    font-size: 0.72rem;
    font-weight: 950;
    text-align: center;
  }

  .compare-grid li {
    display: grid;
    grid-template-columns: 18px minmax(0, 1fr);
    gap: 6px;
    align-items: start;
    padding: 5px 7px;
    border-bottom: 1px solid #ccd1d5;
    color: #111;
    font-size: 0.56rem;
    line-height: 1.12;
  }

  .compare-grid li:last-child {
    border-bottom: 0;
  }

  .compare-grid li span {
    color: var(--red);
    font-size: 0.9rem;
    font-weight: 950;
  }

  .compare-grid > div:last-child li span {
    color: #ff6b00;
  }

  .versus {
    display: grid;
    place-items: center;
    color: #111;
    font-size: 1.55rem;
    font-weight: 950;
  }

  .table-wrap {
    overflow: hidden;
    border: 2px solid var(--line);
    background: white;
  }

  table {
    width: 100%;
    min-width: 100%;
    border-collapse: collapse;
  }

  .schedule-matrix {
    table-layout: fixed;
  }

  th,
  td {
    border-right: 1px solid #c4c9ce;
    border-bottom: 1px solid #c4c9ce;
    padding: 2px 3px;
    color: #111;
    font-size: 0.58rem;
    line-height: 1.05;
    text-align: center;
    vertical-align: middle;
  }

  th {
    background: #f1f4f6;
    font-weight: 950;
  }

  .schedule-matrix th:first-child,
  .schedule-matrix td:first-child {
    width: 76px;
    text-align: center;
    font-weight: 950;
  }

  .schedule-matrix td:not(:first-child) {
    font-size: 0.64rem;
    font-weight: 850;
  }

  .schedule-matrix tr:last-child td {
    border-bottom: 0;
  }

  .schedule-matrix th:last-child,
  .schedule-matrix td:last-child {
    border-right: 0;
  }

  .schedule-matrix .holiday {
    color: #f06b2f;
    font-weight: 950;
  }

  .schedule-legend {
    margin-top: 3px;
    color: #111;
    font-size: 0.54rem;
    font-weight: 820;
    line-height: 1.16;
  }

  .schedule-legend span {
    color: #f06b2f;
    font-weight: 950;
  }

  .price-list {
    display: grid;
    gap: 4px;
  }

  .pricing-panel .panel-heading {
    gap: 8px;
  }

  .pricing-panel .panel-heading h2 {
    flex: 0 0 auto;
    font-size: clamp(0.88rem, 1.05vw, 1rem);
    white-space: nowrap;
  }

  .pricing-panel .panel-heading small {
    flex: 0 0 auto;
    white-space: nowrap;
  }

  .price-list article {
    display: grid;
